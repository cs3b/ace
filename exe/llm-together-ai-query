#!/usr/bin/env ruby

# Backward compatibility wrapper for llm-together-ai-query
# Routes to unified llm-query command with together_ai: prefix

$LOAD_PATH.unshift File.expand_path("../lib", __dir__)

require "coding_agent_tools/molecules/executable_wrapper"

# Convert first argument to together_ai:MODEL format if it doesn't already have provider prefix
if ARGV.length > 0 && ARGV[0].start_with?("--")
  # First arg is an option (like --help), insert default model before it
  ARGV.unshift("together_ai:meta-llama/Llama-3.2-11B-Vision-Instruct-Turbo")
elsif ARGV.length > 0 && !ARGV[0].include?(":")
  # If first arg looks like a model name, prepend together_ai:
  # Otherwise assume it's a prompt and use default model
  if ARGV[0].match?(/^[a-z0-9\-\.]+$/i) && !ARGV[0].include?(" ")
    ARGV[0] = "together_ai:#{ARGV[0]}"
  else
    # Insert default together_ai model before the prompt
    ARGV.unshift("together_ai:meta-llama/Llama-3.2-11B-Vision-Instruct-Turbo")
  end
elsif ARGV.length == 0
  # No arguments, let unified command handle help
  ARGV.unshift("together_ai:meta-llama/Llama-3.2-11B-Vision-Instruct-Turbo")
end

CodingAgentTools::Molecules::ExecutableWrapper.new(
  command_path: ["llm", "unified_query"],
  registration_method: :register_llm_commands,
  executable_name: "llm-together-ai-query"
).call
