#!/usr/bin/env ruby

# Backward compatibility wrapper for llm-mistral-query
# Routes to unified llm-query command with mistral: prefix

$LOAD_PATH.unshift File.expand_path("../lib", __dir__)

require "coding_agent_tools/molecules/executable_wrapper"

# Convert first argument to mistral:MODEL format if it doesn't already have provider prefix
if ARGV.length > 0 && ARGV[0].start_with?("--")
  # First arg is an option (like --help), insert default model before it
  ARGV.unshift("mistral:mistral-large-latest")
elsif ARGV.length > 0 && !ARGV[0].include?(":")
  # If first arg looks like a model name, prepend mistral:
  # Otherwise assume it's a prompt and use default model
  if ARGV[0].match?(/^[a-z0-9\-\.]+$/i) && !ARGV[0].include?(" ")
    ARGV[0] = "mistral:#{ARGV[0]}"
  else
    # Insert default mistral model before the prompt
    ARGV.unshift("mistral:mistral-large-latest")
  end
elsif ARGV.length == 0
  # No arguments, let unified command handle help
  ARGV.unshift("mistral:mistral-large-latest")
end

CodingAgentTools::Molecules::ExecutableWrapper.new(
  command_path: ["llm", "unified_query"],
  registration_method: :register_llm_commands,
  executable_name: "llm-mistral-query"
).call
