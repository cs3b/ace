#!/usr/bin/env ruby
# frozen_string_literal: true

# Nav Tree - Enhanced project tree with intelligent filtering
#
# This executable provides configuration-driven directory tree functionality
# with context-aware filtering and depth control.
#
# Usage: nav-tree [PATH] [OPTIONS]
#
# Examples:
#   nav-tree
#   nav-tree docs
#   nav-tree --context dev
#   nav-tree --depth 3
#   nav-tree guides --context tasks
#
# Options:
#   --context       Tree context (default, dev, tasks, full)
#   --depth         Maximum tree depth
#   --autocorrect   Enable path autocorrection (default: true)
#   --no-autocorrect Disable path autocorrection

# Use absolute path resolution to support execution from any directory
lib_path = File.expand_path('../../lib', __FILE__)
$LOAD_PATH.unshift lib_path unless $LOAD_PATH.include?(lib_path)

require 'coding_agent_tools/molecules/executable_wrapper'

CodingAgentTools::Molecules::ExecutableWrapper.new(
  command_path: ['nav', 'tree'],
  registration_method: :register_nav_commands,
  executable_name: 'nav-tree'
).call
