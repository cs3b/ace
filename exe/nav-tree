#!/usr/bin/env ruby

# Nav Tree - Direct interface to configuration-driven directory tree functionality
# This provides a focused entry point for tree operations

# Set up load paths for development if necessary
# Use absolute path resolution to support execution from any directory
lib_path = File.expand_path("../../lib", __FILE__)
$LOAD_PATH.unshift lib_path unless $LOAD_PATH.include?(lib_path)

require "coding_agent_tools"
require "coding_agent_tools/molecules"
require "coding_agent_tools/cli/commands/nav/tree"

# Simple direct execution - bypass Dry::CLI complexity for a dedicated executable
begin
  if ARGV.include?("--help") || ARGV.include?("-h")
    puts "Nav Tree - Configuration-driven directory tree with filtering and autocorrection"
    puts ""
    puts "Usage:"
    puts "  nav-tree [PATH] [OPTIONS]"
    puts ""
    puts "Options:"
    puts "  --context CONTEXT   Tree context (default, dev, tasks, full)"
    puts "  --depth DEPTH       Maximum tree depth"
    puts "  --autocorrect       Enable path autocorrection suggestions (default: true)"
    puts "  --no-autocorrect    Disable path autocorrection suggestions"
    puts ""
    puts "Examples:"
    puts "  nav-tree"
    puts "  nav-tree guides"
    puts "  nav-tree --context dev"
    puts "  nav-tree docs --depth 4"
    puts "  nav-tree tasks --context tasks --no-autocorrect"
    exit 0
  end

  if ARGV.include?("--version") || ARGV.include?("-v")
    require "coding_agent_tools/version"
    puts "Nav Tree #{CodingAgentTools::VERSION}"
    exit 0
  end

  # Parse arguments manually
  options = {}
  path = nil

  # Extract path argument (first non-option argument)
  non_option_args = ARGV.reject { |arg| arg.start_with?("--") }
  path = non_option_args.first unless non_option_args.empty?

  context_index = ARGV.index("--context")
  if context_index && context_index + 1 < ARGV.length
    options[:context] = ARGV[context_index + 1]
  end

  depth_index = ARGV.index("--depth")
  if depth_index && depth_index + 1 < ARGV.length
    options[:depth] = ARGV[depth_index + 1].to_i
  end

  options[:autocorrect] = if ARGV.include?("--no-autocorrect")
    false
  elsif ARGV.include?("--autocorrect")
    true
  else
    true  # default
  end

  # Execute the nav tree command
  command = CodingAgentTools::Cli::Commands::Nav::Tree.new
  command.call(path: path, **options)
rescue => e
  warn "An unexpected error occurred: #{e.message}"
  warn e.backtrace.join("\n") if ENV["DEBUG"]
  exit 1
end
