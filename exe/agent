#!/usr/bin/env ruby
# frozen_string_literal: true

# Agent - Manage and validate agents with dual compatibility
#
# This executable provides agent management for both Claude Code and MCP proxy.
# It can list, validate, and display enhanced markdown agents.
#
# Usage: agent [options]
#
# Examples:
#   agent --list                    # List all available agents
#   agent --validate agent.md       # Validate an agent file
#   agent --show task-manager       # Display agent content
#
# Features:
#   - List all agents in .claude/agents directory
#   - Validate agent YAML context definitions
#   - Display enhanced agent content with metadata
#   - Support for both Claude Code and MCP proxy formats

# Use absolute path resolution to support execution from any directory
lib_path = File.expand_path("../../lib", __FILE__)
$LOAD_PATH.unshift lib_path unless $LOAD_PATH.include?(lib_path)

require "coding_agent_tools/molecules/executable_wrapper"

CodingAgentTools::Molecules::ExecutableWrapper.new(
  command_path: ["agent"],
  registration_method: :register_agent_commands,
  executable_name: "agent"
).call