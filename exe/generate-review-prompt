#!/usr/bin/env ruby
# frozen_string_literal: true

# Generate Review Prompt for Non-Interactive LLM Processing
# This script creates fully hydrated prompts with embedded content for batch review processing
#
# Usage Examples:
#   Generate code review prompt from diff:
#     dev-tools/exe/generate-review-prompt --focus code --target v.0.2.0..HEAD
#
#   Generate test review prompt from file pattern:
#     dev-tools/exe/generate-review-prompt --focus tests --target "spec/**/*.rb"
#
#   Generate combined review with custom context:
#     dev-tools/exe/generate-review-prompt --focus "code tests docs" --target staged --context custom.md
#
#   Output to file for later processing:
#     dev-tools/exe/generate-review-prompt --focus code --target HEAD~5..HEAD --output review-prompt.md

require "optparse"
require "pathname"
require "fileutils"
require "open3"
require "tmpdir"

class ReviewPromptGenerator
  VALID_FOCUSES = ["code", "tests", "docs"].freeze
  VALID_TARGETS = %w[staged unstaged working].freeze
  VALID_CONTEXTS = %w[auto none].freeze

  def initialize
    @options = {
      focus: nil,
      target: nil,
      context: "auto",
      output_file: nil,
      project_root: Dir.pwd,
      verbose: false,
      model_hint: nil
    }

    parse_options
    validate_options
  end

  def generate
    puts "Generating #{@options[:focus]} review prompt for #{@options[:target]}..." if @options[:verbose]

    focus_areas = parse_focus_areas
    target_content = resolve_target_content
    project_context = load_project_context
    system_prompt = build_system_prompt(focus_areas)

    prompt_content = build_complete_prompt(system_prompt, project_context, target_content, focus_areas)

    write_prompt_file(prompt_content)

    puts "Review prompt generated: #{@options[:output_file]}"
    puts "Ready for processing with: dev-tools/exe/llm-query [model] \"$(cat #{@options[:output_file]})\""
  end

  private

  def parse_options
    OptionParser.new do |opts|
      opts.banner = "Usage: #{File.basename($0)} [options]"
      opts.separator ""
      opts.separator "Generate fully hydrated review prompts for non-interactive LLM processing"
      opts.separator ""
      opts.separator "Examples:"
      opts.separator "  #{File.basename($0)} --focus code --target v.0.2.0..HEAD"
      opts.separator "  #{File.basename($0)} --focus tests --target 'spec/**/*.rb'"
      opts.separator "  #{File.basename($0)} --focus 'code tests docs' --target staged"
      opts.separator ""
      opts.separator "Options:"

      opts.on("-f", "--focus FOCUS", "Review focus area(s): code, tests, docs, or combinations",
        "Examples: 'code', 'tests', 'code tests', 'code tests docs'") do |focus|
        @options[:focus] = focus
      end

      opts.on("-t", "--target TARGET", "Target to review: git range, file pattern, or special keyword",
        "Git ranges: v.0.2.0..HEAD, HEAD~5..HEAD",
        "File patterns: 'lib/**/*.rb', 'spec/**/*.rb'",
        "Special: staged, unstaged, working") do |target|
        @options[:target] = target
      end

      opts.on("-c", "--context CONTEXT", "Project context loading: auto, none, or file path",
        "auto: Load docs/{what-do-we-build,architecture,blueprint}.md",
        "none: Skip project context loading",
        "path: Load custom context file") do |context|
        @options[:context] = context
      end

      opts.on("-o", "--output FILE", "Output file for generated prompt",
        "If not specified, generates: review-prompt-[timestamp].md") do |file|
        @options[:output_file] = file
      end

      opts.on("-r", "--root DIR", "Project root directory (default: current directory)") do |dir|
        @options[:project_root] = dir
      end

      opts.on("-m", "--model-hint MODEL", "Hint for target LLM model (affects prompt optimization)",
        "Examples: gemini, claude, gpt") do |model|
        @options[:model_hint] = model
      end

      opts.on("-v", "--verbose", "Show detailed progress information") do
        @options[:verbose] = true
      end

      opts.on("-h", "--help", "Show this help message") do
        puts opts
        exit
      end
    end.parse!
  end

  def validate_options
    unless @options[:focus]
      puts "Error: Focus area is required. Use --focus to specify."
      puts "Valid focuses: #{VALID_FOCUSES.join(", ")} or combinations"
      exit 1
    end

    unless @options[:target]
      puts "Error: Target is required. Use --target to specify."
      puts "Examples: v.0.2.0..HEAD, 'lib/**/*.rb', staged"
      exit 1
    end

    unless Dir.exist?(@options[:project_root])
      puts "Error: Project root directory not found: #{@options[:project_root]}"
      exit 1
    end

    # Auto-generate output file name if not provided
    unless @options[:output_file]
      timestamp = Time.now.strftime("%Y%m%d-%H%M%S")
      focus_slug = @options[:focus].gsub(/\s+/, "-")
      @options[:output_file] = "review-prompt-#{focus_slug}-#{timestamp}.md"
    end

    # Validate focus areas
    focus_areas = parse_focus_areas
    invalid_focuses = focus_areas - VALID_FOCUSES
    unless invalid_focuses.empty?
      puts "Error: Invalid focus area(s): #{invalid_focuses.join(", ")}"
      puts "Valid focuses: #{VALID_FOCUSES.join(", ")}"
      exit 1
    end
  end

  def parse_focus_areas
    @options[:focus].split(/\s+/)
  end

  def resolve_target_content
    target = @options[:target]
    log_verbose "Resolving target content for: #{target}"

    case target
    when "staged"
      get_git_diff("--staged")
    when "unstaged"
      get_git_diff("")
    when "working"
      get_git_diff("HEAD")
    when /\.\./
      # Git range (e.g., v.0.2.0..HEAD, HEAD~5..HEAD)
      get_git_diff(target)
    when /\*\*/
      # File pattern (e.g., lib/**/*.rb, spec/**/*.rb)
      get_file_pattern_content(target)
    else
      # Check if it's a file path
      if File.exist?(File.join(@options[:project_root], target))
        get_file_content(target)
      else
        # Assume it's a git range
        get_git_diff(target)
      end
    end
  end

  def get_git_diff(range_or_options)
    cmd = if range_or_options.empty?
      "git diff --no-color"
    elsif range_or_options.include?("--")
      "git diff #{range_or_options} --no-color"
    else
      "git diff #{range_or_options} --no-color"
    end

    log_verbose "Executing: #{cmd}"
    output, status = Open3.capture2e(cmd, chdir: @options[:project_root])

    unless status.success?
      puts "Error: Git command failed: #{cmd}"
      puts "Output: #{output}"
      exit 1
    end

    if output.strip.empty?
      puts "Warning: No changes found for target: #{@options[:target]}"
      return "No changes found"
    end

    output
  end

  def get_file_pattern_content(pattern)
    log_verbose "Resolving file pattern: #{pattern}"

    files = Dir.glob(File.join(@options[:project_root], pattern))

    if files.empty?
      puts "Warning: No files found matching pattern: #{pattern}"
      return "No files found matching pattern"
    end

    content_parts = []
    files.sort.each do |file|
      relative_path = Pathname.new(file).relative_path_from(Pathname.new(@options[:project_root]))
      content_parts << "### File: #{relative_path}"
      content_parts << "```#{get_file_extension(file)}"
      content_parts << File.read(file)
      content_parts << "```"
      content_parts << ""
    end

    content_parts.join("\n")
  end

  def get_file_content(file_path)
    full_path = File.join(@options[:project_root], file_path)
    log_verbose "Reading file: #{full_path}"

    unless File.exist?(full_path)
      puts "Error: File not found: #{full_path}"
      exit 1
    end

    relative_path = Pathname.new(full_path).relative_path_from(Pathname.new(@options[:project_root]))
    extension = get_file_extension(full_path)

    [
      "### File: #{relative_path}",
      "```#{extension}",
      File.read(full_path),
      "```"
    ].join("\n")
  end

  def get_file_extension(file_path)
    ext = File.extname(file_path)[1..]
    case ext
    when "rb" then "ruby"
    when "md" then "markdown"
    when "yml", "yaml" then "yaml"
    when "json" then "json"
    else ext || "text"
    end
  end

  def load_project_context
    case @options[:context]
    when "none"
      log_verbose "Skipping project context loading"
      nil
    when "auto"
      log_verbose "Loading automatic project context"
      load_default_project_context
    else
      # Custom context file
      log_verbose "Loading custom context: #{@options[:context]}"
      load_custom_context(@options[:context])
    end
  end

  def load_default_project_context
    project_root = Pathname.new(@options[:project_root])
    context_files = [
      "docs/what-do-we-build.md",
      "docs/architecture.md",
      "docs/blueprint.md"
    ]

    context_parts = []
    context_files.each do |file_path|
      full_path = project_root / file_path
      if full_path.exist?
        log_verbose "Loading context file: #{file_path}"
        context_parts << "## #{File.basename(file_path, ".md").tr("-", " ").titleize}"
        context_parts << File.read(full_path)
        context_parts << ""
      else
        log_verbose "Context file not found: #{file_path}"
      end
    end

    if context_parts.empty?
      log_verbose "No default context files found"
      return nil
    end

    context_parts.join("\n")
  end

  def load_custom_context(context_path)
    full_path = File.expand_path(context_path, @options[:project_root])

    unless File.exist?(full_path)
      puts "Error: Custom context file not found: #{full_path}"
      exit 1
    end

    log_verbose "Loading custom context from: #{full_path}"
    File.read(full_path)
  end

  def build_system_prompt(focus_areas)
    if focus_areas.length == 1
      # Single focus area
      load_single_focus_prompt(focus_areas.first)
    else
      # Multiple focus areas - use primary and add combination instructions
      primary_focus = focus_areas.first
      prompt = load_single_focus_prompt(primary_focus)

      # Add combination instructions
      combination_key = focus_areas.sort.join(" ")
      prompt + build_combination_instructions(combination_key)
    end
  end

  def load_single_focus_prompt(focus)
    template_path = File.join(
      @options[:project_root],
      "dev-handbook",
      "templates",
      "review-#{focus}",
      "system.prompt.md"
    )

    unless File.exist?(template_path)
      puts "Error: System prompt template not found: #{template_path}"
      exit 1
    end

    log_verbose "Loading system prompt: #{template_path}"
    File.read(template_path)
  end

  def build_combination_instructions(combination_key)
    instructions = "\n\n# ACTIVE FOCUS COMBINATION\n\n"

    instructions += case combination_key
    when "code tests"
      "Apply 'code tests' focus combination instructions from the system prompt."
    when "code docs"
      "Apply 'code docs' focus combination instructions from the system prompt."
    when "docs tests"
      "Apply 'docs tests' focus combination instructions from the system prompt."
    when "code docs tests"
      "Apply 'code tests docs' focus combination instructions from the system prompt."
    else
      "This is a custom focus combination. Adapt the review to cover all specified areas comprehensively."
    end

    instructions
  end

  def build_complete_prompt(system_prompt, project_context, target_content, focus_areas)
    prompt_parts = []

    # System prompt
    prompt_parts << system_prompt

    # Project context (if available)
    if project_context
      prompt_parts << ""
      prompt_parts << "# PROJECT CONTEXT"
      prompt_parts << ""
      prompt_parts << project_context
    end

    # Target content
    prompt_parts << ""
    prompt_parts << "# CONTENT TO REVIEW"
    prompt_parts << ""
    if @options[:target].include?("..") || VALID_TARGETS.include?(@options[:target])
      prompt_parts << "## Code Diff"
      prompt_parts << "```diff"
      prompt_parts << target_content
      prompt_parts << "```"
    else
      prompt_parts << "## Files/Content"
      prompt_parts << target_content
    end

    # Review instructions
    prompt_parts << ""
    prompt_parts << "# REVIEW INSTRUCTIONS"
    prompt_parts << ""
    prompt_parts << "Please perform a comprehensive #{focus_areas.join(" and ")} review of the provided content."
    prompt_parts << "Follow the structured format specified in the system prompt."
    prompt_parts << "Focus on actionable recommendations with specific file locations and line numbers where applicable."

    # Model-specific optimizations
    if @options[:model_hint]
      prompt_parts << ""
      prompt_parts << "# MODEL OPTIMIZATION"
      prompt_parts << ""
      case @options[:model_hint].downcase
      when "gemini"
        prompt_parts << "Optimize response for Google Gemini: Use clear section headers and bullet points."
      when "claude"
        prompt_parts << "Optimize response for Claude: Provide detailed analysis with specific examples."
      when "gpt"
        prompt_parts << "Optimize response for GPT: Use structured format with consistent terminology."
      end
    end

    prompt_parts.join("\n")
  end

  def write_prompt_file(content)
    output_path = File.expand_path(@options[:output_file], @options[:project_root])
    FileUtils.mkdir_p(File.dirname(output_path))

    File.write(output_path, content)
    log_verbose "Wrote #{content.length} bytes to #{output_path}"
  rescue => e
    puts "Error writing prompt file: #{e.message}"
    exit 1
  end

  def log_verbose(message)
    puts "[DEBUG] #{message}" if @options[:verbose]
  end
end

# String extensions for titleization
class String
  def titleize
    split(/[\s_-]+/).map(&:capitalize).join(" ")
  end
end

# Main execution
if __FILE__ == $0
  generator = ReviewPromptGenerator.new
  generator.generate
end
