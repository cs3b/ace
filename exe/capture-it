#!/usr/bin/env ruby

# Capture It - Streamlined tool for capturing ideas
# This provides intuitive entry point for idea capture operations

# Ensure we use the correct Gemfile regardless of current directory
gem_gemfile_path = File.expand_path("../../Gemfile", __FILE__)
ENV["BUNDLE_GEMFILE"] = gem_gemfile_path if File.exist?(gem_gemfile_path)

begin
  require "bundler/setup"
rescue LoadError
  # Continue without bundler if not available
end

# Set up load paths for development if necessary
# Use absolute path resolution to support execution from any directory
lib_path = File.expand_path("../../lib", __FILE__)
$LOAD_PATH.unshift lib_path unless $LOAD_PATH.include?(lib_path)

require "coding_agent_tools/cli/commands/ideas/capture"
require "dry/cli"

module CaptureItCli
  module Commands
    extend Dry::CLI::Registry

    # Register the capture command as the default/root command
    register "", CodingAgentTools::Cli::Commands::Ideas::Capture
  end
end

begin
  Dry::CLI.new(CaptureItCli::Commands).call
rescue Dry::CLI::Error => e
  warn "Error: #{e.message}"
  exit 1
rescue => e
  warn "An unexpected error occurred: #{e.message}"
  warn e.backtrace.join("\n") if ENV["DEBUG"]
  exit 1
end
