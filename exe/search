#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require "json"
require_relative "../lib/coding_agent_tools"

module CodingAgentTools
  module CLI
    class SearchCommand
      def initialize
        @options = {
          type: nil,
          format: :text,
          max_results: nil,
          case_insensitive: false,
          whole_word: false,
          multi_line: false,
          show_context: 0,
          repositories: :all,
          interactive: false,
          preset: nil,
          since: nil,
          before: nil,
          scope: nil,
          glob: nil,
          exclude: []
        }
        
        @unified_searcher = Organisms::Search::UnifiedSearcher.new
        @preset_manager = Molecules::Search::PresetManager.new
      end

      def run(args)
        pattern = parse_arguments(args)
        
        if pattern.nil? || pattern.empty?
          if @options[:list_presets]
            list_presets
          elsif @options[:list_repos]
            list_repositories
          else
            puts "Error: No search pattern provided"
            puts "Usage: search [options] PATTERN"
            exit 1
          end
        else
          execute_search(pattern)
        end
      rescue => e
        puts "Error: #{e.message}"
        puts e.backtrace if ENV["DEBUG"]
        exit 1
      end

      private

      def parse_arguments(args)
        parser = OptionParser.new do |opts|
          opts.banner = "Usage: search [options] PATTERN"
          opts.separator ""
          opts.separator "Search across the codebase with intelligent pattern matching"
          opts.separator ""
          opts.separator "Options:"

          # Search type options
          opts.on("-t", "--type TYPE", %w[file content hybrid auto], 
                  "Search type (file, content, hybrid, auto)") do |t|
            @options[:type] = t.to_sym
          end

          opts.on("-f", "--files", "Search for files only") do
            @options[:type] = :file
          end

          opts.on("-c", "--content", "Search in file content only") do
            @options[:type] = :content
          end

          # Pattern matching options
          opts.on("-i", "--case-insensitive", "Case insensitive search") do
            @options[:case_insensitive] = true
          end

          opts.on("-w", "--whole-word", "Match whole words only") do
            @options[:whole_word] = true
          end

          opts.on("-U", "--multiline", "Enable multiline matching") do
            @options[:multi_line] = true
          end

          # Context options
          opts.on("-A", "--after NUM", Integer, "Show NUM lines after match") do |n|
            @options[:after_context] = n
          end

          opts.on("-B", "--before NUM", Integer, "Show NUM lines before match") do |n|
            @options[:before_context] = n
          end

          opts.on("-C", "--context NUM", Integer, "Show NUM lines of context") do |n|
            @options[:show_context] = n
          end

          # Repository options
          opts.on("-r", "--repository REPO", "Search in specific repository") do |repo|
            @options[:repository] = repo
          end

          opts.on("-m", "--main-only", "Search main repository only") do
            @options[:main_only] = true
          end

          # File filtering options
          opts.on("-g", "--glob PATTERN", "File glob pattern to include") do |glob|
            @options[:glob] = glob
          end

          opts.on("-e", "--exclude PATTERN", "Pattern to exclude") do |pattern|
            @options[:exclude] << pattern
          end

          opts.on("--since TIME", "Files modified since TIME") do |time|
            @options[:since] = time
          end

          opts.on("--before TIME", "Files modified before TIME") do |time|
            @options[:before] = time
          end

          # Git scope options
          opts.on("--staged", "Search staged files only") do
            @options[:scope] = :staged
          end

          opts.on("--tracked", "Search tracked files only") do
            @options[:scope] = :tracked
          end

          opts.on("--changed", "Search changed files only") do
            @options[:scope] = :changed
          end

          # Output options
          opts.on("--json", "Output in JSON format") do
            @options[:format] = :json
          end

          opts.on("--yaml", "Output in YAML format") do
            @options[:format] = :yaml
          end

          opts.on("-l", "--files-with-matches", "Only print filenames") do
            @options[:files_only] = true
          end

          opts.on("--max-results NUM", Integer, "Limit number of results") do |n|
            @options[:max_results] = n
          end

          # Interactive options
          opts.on("--fzf", "Use fzf for interactive selection") do
            @options[:interactive] = true
          end

          # Preset options
          opts.on("-p", "--preset NAME", "Use search preset") do |name|
            @options[:preset] = name
          end

          opts.on("--list-presets", "List available presets") do
            @options[:list_presets] = true
          end

          # Information options
          opts.on("--list-repos", "List available repositories") do
            @options[:list_repos] = true
          end

          opts.on("-h", "--help", "Show this help message") do
            puts opts
            exit
          end

          opts.on("-v", "--version", "Show version") do
            puts "search v1.0.0"
            exit
          end
        end

        parser.parse!(args)
        args.join(" ")
      end

      def execute_search(pattern)
        # Apply preset if specified
        if @options[:preset]
          apply_preset(@options[:preset])
        end

        # Perform search (don't pass format to the searcher)
        search_options = @options.dup
        search_options.delete(:format)  # Remove format, handle it in CLI
        results = @unified_searcher.search(pattern, search_options)
        
        # Handle interactive mode
        if @options[:interactive]
          handle_interactive_results(results)
        else
          output_results(results)
        end
      end

      def apply_preset(preset_name)
        unless @preset_manager.exists?(preset_name)
          puts "Error: Preset '#{preset_name}' not found"
          exit 1
        end
        
        preset = @preset_manager.get(preset_name)
        @options.merge!(preset.transform_keys(&:to_sym))
      end

      def list_presets
        puts "Available search presets:"
        @preset_manager.list.each do |name|
          preset = @preset_manager.get(name)
          puts "  #{name}: #{preset['description'] || 'No description'}"
        end
      end

      def list_repositories
        puts "Available repositories:"
        @unified_searcher.repositories.each do |repo|
          status = repo[:status][:is_git] ? "(#{repo[:status][:branch]})" : "(not git)"
          puts "  #{repo[:name]}: #{repo[:path]} #{status}"
        end
      end

      def handle_interactive_results(results)
        require_relative "../lib/coding_agent_tools/molecules/search/fzf_integrator"
        
        fzf = Molecules::Search::FzfIntegrator.new(multi: true)
        
        unless fzf.available?
          puts "Error: fzf is not installed. Install with: brew install fzf"
          exit 1
        end
        
        # Format results for fzf
        items = []
        results[:repositories].each do |repo_name, repo_data|
          repo_data[:results].each do |result|
            if result[:line]
              items << "#{repo_name}:#{result[:file]}:#{result[:line]}: #{result[:text]}"
            else
              items << "#{repo_name}:#{result}"
            end
          end
        end
        
        selection = fzf.select_interactive(items, prompt: "Select results")
        
        if selection[:success]
          puts "Selected:"
          selection[:selected].each { |item| puts "  #{item}" }
        end
      end

      def output_results(results)
        case @options[:format]
        when :json
          puts JSON.pretty_generate(results)
        when :yaml
          require "yaml"
          puts YAML.dump(results)
        else
          output_text_results(results)
        end
      end

      def output_text_results(results)
        if results[:total_results] == 0
          puts "No results found"
          return
        end
        
        puts "Found #{results[:total_results]} results across #{results[:repositories].size} repositories"
        puts
        
        results[:repositories].each do |repo_name, repo_data|
          next if repo_data[:count] == 0
          
          puts "#{repo_name}: (#{repo_data[:count]} results)"
          
          if repo_data[:results].is_a?(Array)
            repo_data[:results].each do |result|
              output_single_result(result)
            end
          elsif repo_data[:results].is_a?(Hash)
            if repo_data[:results][:files]
              puts "  Files:"
              repo_data[:results][:files].each { |f| puts "    #{f}" }
            end
            if repo_data[:results][:content]
              puts "  Content:"
              repo_data[:results][:content].each { |r| output_single_result(r) }
            end
          end
          
          puts
        end
      end

      def output_single_result(result)
        if @options[:files_only]
          puts "  #{result[:file] || result[:path] || result}"
        elsif result[:line]
          puts "  #{result[:file]}:#{result[:line]}:#{result[:column] || 0}: #{result[:text]}"
        else
          puts "  #{result[:file] || result[:path] || result}"
        end
      end
    end
  end
end

# Run the command
CodingAgentTools::CLI::SearchCommand.new.run(ARGV) if __FILE__ == $PROGRAM_NAME