#!/usr/bin/env ruby
# frozen_string_literal: true

# Add the lib directory to the load path
$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "bundler/setup"
require "dry/cli"
require "coding_agent_tools/version"

# Only require what we need for code-lint
require_relative "../lib/coding_agent_tools/cli/commands/code/lint"

module CodingAgentTools
  module Cli
    module Commands
      extend Dry::CLI::Registry
      
      # Register only the lint command
      register "lint", Code::Lint
    end
  end
end

# Run the CLI with the lint command
Dry::CLI.new(CodingAgentTools::Cli::Commands).call