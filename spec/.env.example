# Test Environment Configuration for coding-agent-tools specs
# Copy this file to .env and fill in your actual values for recording new VCR cassettes

# Google Gemini API Key (required for recording new cassettes)
# Get this from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_actual_gemini_api_key_here

# VCR Recording Mode
# Set to 'true' to record new cassettes with real API calls
# Leave commented or set to 'false' to use existing cassettes
VCR_RECORD=false

# Test Configuration
# Uncomment to enable debug output during tests
# TEST_DEBUG=true

# Alternative API endpoint (if needed for testing)
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com

# Timeout settings for integration tests (in seconds)
# TEST_TIMEOUT=30
