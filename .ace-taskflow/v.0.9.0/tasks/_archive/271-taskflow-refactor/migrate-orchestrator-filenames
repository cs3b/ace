#!/usr/bin/env ruby
# frozen_string_literal: true

# Migration script: Rename .00 orchestrator files to new naming convention
#
# Old: NNN.00-orchestrator.s.md (or NNN.00-anything.s.md)
# New: NNN-orchestrator.s.md
#
# Walks .ace-taskflow/ recursively. Idempotent (safe to run multiple times).
#
# Usage:
#   ruby bin/migrate-orchestrator-filenames [--dry-run]

require "fileutils"

DRY_RUN = ARGV.include?("--dry-run")
TASKFLOW_ROOT = File.join(Dir.pwd, ".ace-taskflow")

unless File.directory?(TASKFLOW_ROOT)
  warn "Error: .ace-taskflow/ directory not found in #{Dir.pwd}"
  exit 1
end

# Pattern: NNN.00-anything.s.md
ORCHESTRATOR_OLD_PATTERN = /^(\d+)\.00-.*\.s\.md$/

renamed = 0
skipped = 0
errors = 0

Dir.glob(File.join(TASKFLOW_ROOT, "**", "*.00-*.s.md")).sort.each do |old_path|
  filename = File.basename(old_path)
  next unless filename.match?(ORCHESTRATOR_OLD_PATTERN)

  match = filename.match(/^(\d+)\.00-/)
  task_number = match[1]
  new_filename = "#{task_number}-orchestrator.s.md"
  new_path = File.join(File.dirname(old_path), new_filename)

  if old_path == new_path
    skipped += 1
    next
  end

  if File.exist?(new_path)
    warn "SKIP: #{old_path} -> #{new_path} (target already exists)"
    skipped += 1
    next
  end

  relative_old = old_path.sub("#{Dir.pwd}/", "")
  relative_new = new_path.sub("#{Dir.pwd}/", "")

  if DRY_RUN
    puts "[DRY-RUN] #{relative_old} -> #{relative_new}"
    renamed += 1
  else
    begin
      FileUtils.mv(old_path, new_path)
      puts "Renamed: #{relative_old} -> #{relative_new}"
      renamed += 1
    rescue StandardError => e
      warn "ERROR: #{relative_old}: #{e.message}"
      errors += 1
    end
  end
end

prefix = DRY_RUN ? "[DRY-RUN] " : ""
puts "\n#{prefix}Done: #{renamed} renamed, #{skipped} skipped, #{errors} errors"
