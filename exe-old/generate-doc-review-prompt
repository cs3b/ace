#!/usr/bin/env ruby
# frozen_string_literal: true

# Generate Documentation Review Prompt
# This script creates a comprehensive prompt for AI agents to review code diffs
# and update related documentation systematically.
#
# Usage Examples:
#   Generate prompt from a diff file:
#     dev-handbook/tools/generate-doc-review-prompt -d changes.diff
#
#   Specify custom output location:
#     dev-handbook/tools/generate-doc-review-prompt -d changes.diff -o review-prompt.md
#
#   Include full documentation content for detailed analysis:
#     dev-handbook/tools/generate-doc-review-prompt -d changes.diff --include-content

require 'optparse'
require 'pathname'
require 'fileutils'

class DocReviewPromptGenerator
  def initialize
    @options = {
      diff_file: nil,
      output_file: nil,
      project_root: Dir.pwd,
      include_content: false
    }

    parse_options
    validate_options
  end

  def generate
    puts "Generating documentation review prompt..."

    diff_content = read_diff_file
    doc_state = collect_documentation_state

    prompt_content = build_prompt(diff_content, doc_state)

    write_prompt_file(prompt_content)

    puts "Documentation review prompt generated: #{@options[:output_file]}"
    puts "Use this prompt with your AI agent to get comprehensive documentation update recommendations."
  end

  private

  def parse_options
    OptionParser.new do |opts|
      opts.banner = "Usage: #{File.basename($0)} [options]"
      opts.separator ""
      opts.separator "Generate a comprehensive documentation review prompt from a diff file"
      opts.separator ""
      opts.separator "Examples:"
      opts.separator "  #{File.basename($0)} -d changes.diff"
      opts.separator "  #{File.basename($0)} -d changes.diff -o custom-prompt.md"
      opts.separator "  #{File.basename($0)} -d changes.diff --include-content"
      opts.separator ""
      opts.separator "Options:"

      opts.on("-d", "--diff FILE", "Path to the diff file (required)") do |file|
        @options[:diff_file] = file
      end

      opts.on("-o", "--output FILE", "Output file for the prompt (optional)",
              "If not specified, generates: <diff-basename>-doc-review-prompt.md") do |file|
        @options[:output_file] = file
      end

      opts.on("-r", "--root DIR", "Project root directory (default: current directory)") do |dir|
        @options[:project_root] = dir
      end

      opts.on("-c", "--include-content", "Include full content of documentation files",
              "(default: just list files for faster processing)") do
        @options[:include_content] = true
      end

      opts.on("-h", "--help", "Show this help message") do
        puts opts
        exit
      end
    end.parse!
  end

  def validate_options
    unless @options[:diff_file]
      puts "Error: Diff file is required. Use -d or --diff to specify."
      puts "Run '#{File.basename($0)} --help' for usage examples."
      exit 1
    end

    unless File.exist?(@options[:diff_file])
      puts "Error: Diff file not found: #{@options[:diff_file]}"
      puts "Please check the file path and try again."
      exit 1
    end

    # Validate project root exists
    unless Dir.exist?(@options[:project_root])
      puts "Error: Project root directory not found: #{@options[:project_root]}"
      exit 1
    end

    # Auto-generate output file name if not provided
    unless @options[:output_file]
      diff_basename = File.basename(@options[:diff_file], '.*')
      diff_dir = File.dirname(@options[:diff_file])
      @options[:output_file] = File.join(diff_dir, "#{diff_basename}-doc-review-prompt.md")
    end
  end

  def read_diff_file
    File.read(@options[:diff_file])
  rescue => e
    puts "Error reading diff file: #{e.message}"
    exit 1
  end

  def collect_documentation_state
    project_root = Pathname.new(@options[:project_root])

    {
      adrs: collect_adrs(project_root),
      project_docs: collect_project_docs(project_root),
      root_docs: collect_root_docs(project_root),
      tech_docs: collect_tech_docs(project_root),
      key_docs: collect_key_docs(project_root)
    }
  end

  def collect_adrs(project_root)
    adr_dir = project_root / 'dev-taskflow' / 'decisions'
    return ["No ADRs directory found"] unless adr_dir.exist?

    files = Dir.glob(adr_dir / '*.md').sort
    if files.empty?
      ["No ADR files found (only .keep file exists)"]
    else
      files.map { |f| format_file_info(f, project_root) }
    end
  end

  def collect_project_docs(project_root)
    docs_dir = project_root / 'dev-taskflow'
    return ["No dev-taskflow directory found"] unless docs_dir.exist?

    files = Dir.glob(docs_dir / '*.md').reject { |f| File.basename(f) == 'roadmap.md' }.sort
    files.map { |f| format_file_info(f, project_root) }
  end

  def collect_root_docs(project_root)
    files = Dir.glob(project_root / '*.md').sort
    files.map { |f| format_file_info(f, project_root) }
  end

  def collect_tech_docs(project_root)
    docs_dir = project_root / 'docs'
    return ["No docs directory found"] unless docs_dir.exist?

    files = Dir.glob(docs_dir / '**' / '*.md').sort
    files.map { |f| format_file_info(f, project_root) }
  end

  def collect_key_docs(project_root)
    # Key documentation files that should always be included as context
    key_files = [
      'README.md',
      'docs/architecture.md',
      'docs/blueprint.md',
      'docs/DEVELOPMENT.md',
      'docs/what-do-we-build.md'
    ]

    key_files.map do |file_path|
      full_path = project_root / file_path
      if full_path.exist?
        format_key_doc_with_content(full_path, project_root)
      else
        "#{file_path}: Not found"
      end
    end.compact
  end

  def format_key_doc_with_content(file_path, project_root)
    relative_path = Pathname.new(file_path).relative_path_from(project_root)
    content = File.read(file_path).strip
    "#{relative_path}:\n#{content}\n---"
  rescue => e
    "#{relative_path}: Error reading - #{e.message}"
  end

  def format_file_info(file_path, project_root)
    relative_path = Pathname.new(file_path).relative_path_from(project_root)

    if @options[:include_content]
      content = File.read(file_path).strip
      "#{relative_path}:\n#{content}\n---"
    else
      relative_path.to_s
    end
  rescue => e
    "#{relative_path} (Error reading: #{e.message})"
  end

  def build_prompt(diff_content, doc_state)
    template = read_prompt_template

    template
      .gsub('[INSERT YOUR DIFF CONTENT HERE]', diff_content)
      .gsub('[LIST YOUR CURRENT ADR FILES HERE]', format_list(doc_state[:adrs]))
      .gsub('[LIST YOUR PROJECT DOCUMENTATION FILES HERE]', format_list(doc_state[:project_docs]))
      .gsub('[LIST YOUR ROOT MARKDOWN FILES HERE]', format_list(doc_state[:root_docs]))
      .gsub('[LIST YOUR TECHNICAL DOCUMENTATION FILES HERE]', format_list(doc_state[:tech_docs]))
      .gsub('[INSERT KEY DOCUMENTATION CONTENT HERE]', format_key_docs(doc_state[:key_docs]))
  end

  def read_prompt_template
    # Try multiple possible locations for the template
    possible_paths = [
      File.join(@options[:project_root], '.dev', 'handbook', 'gds', 'review', '_handbook.md'),
      File.join(Dir.pwd, '.dev', 'handbook', 'gds', 'review', '_handbook.md'),
      File.join(__dir__, '..', '..', '.dev', 'handbook', 'gds', 'review', '_handbook.md')
    ]

    template_path = possible_paths.find { |path| File.exist?(path) }

    unless template_path
      puts "Error: Prompt template not found. Searched in:"
      possible_paths.each { |path| puts "  - #{path}" }
      puts ""
      puts "Make sure you're running from the project root or that the dev-handbook"
      puts "directory structure is properly set up."
      exit 1
    end

    File.read(template_path)
  rescue => e
    puts "Error reading prompt template: #{e.message}"
    exit 1
  end

  def format_list(items)
    return "None found" if items.empty?

    if @options[:include_content]
      items.join("\n\n")
    else
      items.map { |item| "- #{item}" }.join("\n")
    end
  end

  def format_key_docs(key_docs)
    return "No key documentation found" if key_docs.empty?
    
    key_docs.join("\n\n")
  end

  def write_prompt_file(content)
    FileUtils.mkdir_p(File.dirname(@options[:output_file]))
    File.write(@options[:output_file], content)
  rescue => e
    puts "Error writing prompt file: #{e.message}"
    exit 1
  end
end

# Main execution
if __FILE__ == $0
  generator = DocReviewPromptGenerator.new
  generator.generate
end
