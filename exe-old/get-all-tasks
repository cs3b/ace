#!/usr/bin/env ruby

require 'pathname'
require 'yaml'
require 'set'

# --- Configuration ---
# These paths are relative to the project root where the script is expected to be run from.
BASE_PATH = Pathname.new("docs-project")
CURRENT_RELEASES_DIR = BASE_PATH / "current"
BACKLOG_RELEASES_DIR = BASE_PATH / "backlog"
TASKS_SUBDIR_NAME = "tasks"

# Regex to validate a pure version string like "v.0.1.0"
VERSION_REGEX = /^v\.\d+\.\d+\.\d+$/
# Regex to extract "v.X.Y.Z" from a directory name like "v.X.Y.Z-codename"
RELEASE_DIR_VERSION_REGEX = /^(v\.\d+\.\d+\.\d+)/

# ANSI escape codes for color
GREEN = "\e[32m"
RESET = "\e[0m"

# --- Helper Functions ---

# Finds a release directory (e.g., vX.Y.Z-codename) given a version string (e.g., vX.Y.Z)
# Searches in specified search_paths. Returns the first full Pathname object found.
def find_release_dir_by_version(version_str, search_paths)
  search_paths.each do |base_dir|
    next unless base_dir.exist? && base_dir.directory?
    
    matching_dirs = base_dir.children.select do |child|
      child.directory? && child.basename.to_s.start_with?(version_str)
    end

    if matching_dirs.size > 1
      warn "Warning: Multiple release directories found starting with '#{version_str}' in #{base_dir}: #{matching_dirs.map(&:basename).join(', ')}. Using the first one found: #{matching_dirs.first.basename}."
      return matching_dirs.first 
    elsif matching_dirs.size == 1
      return matching_dirs.first
    end
  end
  nil
end

# Gets the current release directory from CURRENT_RELEASES_DIR
# Expects exactly one subdirectory in CURRENT_RELEASES_DIR.
def get_current_release_dir
  unless CURRENT_RELEASES_DIR.exist? && CURRENT_RELEASES_DIR.directory?
    abort "Error: Current releases directory does not exist: #{CURRENT_RELEASES_DIR}"
  end

  subdirs = CURRENT_RELEASES_DIR.children.select(&:directory?)
  
  if subdirs.size == 1
    return subdirs.first
  elsif subdirs.empty?
    abort "Error: No release directories found in #{CURRENT_RELEASES_DIR} to use as default."
  else
    abort "Error: Multiple release directories found in #{CURRENT_RELEASES_DIR}: #{subdirs.map(&:basename).join(', ')}. Please specify a release version or path."
  end
end

# Helper function to parse task ID for sorting by its sequential number.
def parse_task_sequential_number(task_id_str)
  return Float::INFINITY unless task_id_str && task_id_str.is_a?(String)
  match = task_id_str.match(/\+task\.(\d+)$/)
  match ? match[1].to_i : Float::INFINITY
end

# Extracts H1 title from markdown content (after frontmatter)
def extract_h1_title(markdown_content_after_fm)
  match = markdown_content_after_fm.match(/^\s*#\s+(.+)/)
  match ? match[1].strip : '(No Title)'
end

# --- Main Script ---

# 1. Argument Parsing and Directory Identification
input_arg = ARGV[0]
release_dir_path = nil

if input_arg.nil?
  release_dir_path = get_current_release_dir
elsif input_arg.include?('/') || input_arg.include?('\\') # Argument is a path
  release_dir_path = Pathname.new(input_arg).expand_path
  unless release_dir_path.exist? && release_dir_path.directory?
    abort "Error: Specified release path does not exist or is not a directory: #{release_dir_path}"
  end
elsif input_arg.match?(VERSION_REGEX) # Argument is a version string like "v0.1.0"
  release_dir_path = find_release_dir_by_version(input_arg, [CURRENT_RELEASES_DIR, BACKLOG_RELEASES_DIR])
  unless release_dir_path
    abort "Error: Could not find a release directory starting with version '#{input_arg}' in #{CURRENT_RELEASES_DIR} or #{BACKLOG_RELEASES_DIR}."
  end
else
  abort "Usage: #{$PROGRAM_NAME} [version (v.X.Y.Z) | path/to/release/folder (e.g., docs-project/current/v.X.Y.Z-codename)]\\n       (No arguments defaults to the unique release in #{CURRENT_RELEASES_DIR})"
end

tasks_dir = release_dir_path / TASKS_SUBDIR_NAME
unless tasks_dir.exist? && tasks_dir.directory?
  puts "No tasks found in #{tasks_dir} (directory does not exist or is not accessible)."
  exit 0
end

# 2. Scan Task Files & Collect Task Data
all_tasks = []
task_id_to_task = {}

Dir.glob(tasks_dir / "*.md").each do |file_path_str|
  file_path = Pathname.new(file_path_str)
  content = File.read(file_path, encoding: "UTF-8")
  
  parts = content.split(/^---\s*$/m, 3)
  next unless parts.length > 2 && (parts[0].nil? || parts[0].strip.empty?) # Basic check for frontmatter
  
  frontmatter_text = parts[1]
  body_text = parts[2] || ""

  begin
    fm = YAML.safe_load(frontmatter_text)
    task_id = fm['id']&.to_s
    next unless task_id # Skip if no ID

    status = fm['status']&.to_s || 'unknown'
    
    raw_deps = fm['dependencies']
    dependencies_list = []
    if raw_deps.is_a?(String)
      dependencies_list = raw_deps.split(',').map(&:strip).reject(&:empty?)
    elsif raw_deps.is_a?(Array)
      dependencies_list = raw_deps.map(&:to_s).reject(&:empty?)
    end

    title = extract_h1_title(body_text)

    task_data = {
      id: task_id,
      status: status,
      title: title,
      dependencies: dependencies_list, # Parsed list of dependency IDs
      path: file_path.to_s,
      raw_deps_for_display: dependencies_list # For display, use the parsed list
    }
    all_tasks << task_data
    task_id_to_task[task_id] = task_data
  rescue Psych::SyntaxError => e
    warn "Warning: Could not parse YAML frontmatter in #{file_path.basename}: #{e.message}. Skipping."
  rescue StandardError => e
    warn "Warning: Error processing task file #{file_path.basename}: #{e.message}. Skipping."
  end
end

if all_tasks.empty?
  puts "No tasks found or parsed in #{tasks_dir}."
  exit 0
end

# 3. Identify the Next Actionable Task (logic adapted from bin/tn)
done_ids = all_tasks.select { |t| t[:status]&.downcase == 'done' }.map { |t| t[:id] }.to_set
all_task_ids_in_release_set = all_tasks.map { |t| t[:id] }.to_set

actionable_candidates = all_tasks.select do |t|
  next if t[:status]&.downcase == 'done'
  # A task is actionable if all its dependencies are either 'done' or not present in this release's set of tasks
  unmet_dependencies = t[:dependencies].any? do |dep_id|
    all_task_ids_in_release_set.include?(dep_id) && !done_ids.include?(dep_id)
  end
  !unmet_dependencies
end

actionable_candidates.sort_by! do |t|
  status_priority = case t[:status]&.downcase
                    when 'in-progress' then 0
                    when 'pending'     then 1
                    else 2 # Other non-done statuses
                    end
  [status_priority, parse_task_sequential_number(t[:id]), t[:id].to_s]
end
next_actionable_task_id = actionable_candidates.first&.[](:id)


# 4. Topological Sort of all_tasks
sorted_tasks = []
processed_ids = Set.new

# Calculate initial in-degrees and direct dependents (adjacency list for reversed graph)
in_degree = Hash.new(0)
# task_dependents maps a task_id to a list of task_ids that depend on it
task_dependents = Hash.new { |h, k| h[k] = [] }

all_tasks.each do |task|
  task[:dependencies].each do |dep_id|
    if task_id_to_task.key?(dep_id) # Only consider intra-release dependencies for in-degree
      in_degree[task[:id]] += 1
      task_dependents[dep_id] << task[:id]
    end
  end
end

# Iteratively build the sorted list
loop do
  # Find all tasks that are ready in this iteration:
  # - in_degree is 0 (all internal dependencies met)
  # - Not yet processed
  current_processing_candidates_ids = task_id_to_task.keys.select do |tid|
    in_degree[tid] == 0 && !processed_ids.include?(tid)
  end
  
  break if current_processing_candidates_ids.empty?

  # Sort this batch by task number, then ID string, then add to sorted_tasks
  current_processing_candidates_ids.sort_by! do |tid|
    task = task_id_to_task[tid]
    [parse_task_sequential_number(task[:id]), task[:id].to_s]
  end

  current_processing_candidates_ids.each do |task_id_to_process|
    task_obj = task_id_to_task[task_id_to_process]
    sorted_tasks << task_obj
    processed_ids.add(task_id_to_process)

    # For each task that depended on the processed task, decrement its in_degree
    task_dependents[task_id_to_process].each do |dependent_id|
      if task_id_to_task.key?(dependent_id) # Should always be true if populated correctly
         in_degree[dependent_id] -= 1
      end
    end
  end
end

# Cycle check / Unresolved dependencies check
if sorted_tasks.length < all_tasks.length
  warn "Warning: Cycle detected or unresolved/external dependencies prevent full topological sort."
  warn "Displaying #{sorted_tasks.length} out of #{all_tasks.length} tasks that could be ordered."
  # Optionally, list tasks not included:
  # remaining_tasks = all_tasks.reject { |t| processed_ids.include?(t[:id]) }
  # warn "Unsorted tasks: #{remaining_tasks.map { |t| t[:id] }.join(', ')}"
end


# 5. Format and Print Output
puts "Tasks for release: #{release_dir_path.basename}"
puts "Found #{all_tasks.size} tasks. Sorted #{sorted_tasks.size} tasks."
puts "Next actionable task highlighted in green."
puts "---"

sorted_tasks.each do |task|
  is_next = (task[:id] == next_actionable_task_id)
  
  line1 = "#{task[:id]}, #{task[:status]}, #{task[:title]}"
  
  deps_display_list = task[:raw_deps_for_display]
  line2_deps_str = if deps_display_list.nil? || deps_display_list.empty?
                     "No dependencies"
                   else
                     "Dependencies: #{deps_display_list.join(', ')}"
                   end
  line2 = "  #{line2_deps_str}"
  
  if is_next
    puts "#{GREEN}#{line1}#{RESET}"
    puts "#{GREEN}#{line2}#{RESET}"
  else
    puts line1
    puts line2
  end
end

if sorted_tasks.empty? && !all_tasks.empty?
    puts "\nNo tasks could be topologically sorted. Check for circular dependencies or external/missing dependencies."
end