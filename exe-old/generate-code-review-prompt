#!/usr/bin/env ruby
# frozen_string_literal: true

# Generate Code Review Prompt
# This script creates a comprehensive prompt for AI agents to review code diffs
# with focus on Ruby gem best practices, ATOM architecture, StandardRB compliance, and code quality.
#
# Usage Examples:
#   Generate prompt from a diff file:
#     docs-dev/tools/generate-code-review-prompt -d changes.diff
#
#   Specify custom output location:
#     docs-dev/tools/generate-code-review-prompt -d changes.diff -o review-prompt.md
#
#   Include full gem dependencies list:
#     docs-dev/tools/generate-code-review-prompt -d changes.diff --include-dependencies

require 'optparse'
require 'pathname'
require 'fileutils'
require 'open3'
require 'json'

class CodeReviewPromptGenerator
  def initialize
    @options = {
      diff_file: nil,
      output_file: nil,
      project_root: Dir.pwd,
      include_dependencies: false,
      verbose: false
    }

    parse_options
    validate_options
  end

  def generate
    puts "Generating code review prompt..."

    diff_content = read_diff_file
    project_state = collect_project_state

    prompt_content = build_prompt(diff_content, project_state)

    write_prompt_file(prompt_content)

    puts "Code review prompt generated: #{@options[:output_file]}"
    puts "Use this prompt with your AI agent to get comprehensive code review feedback."
  end

  private

  def parse_options
    OptionParser.new do |opts|
      opts.banner = "Usage: #{File.basename($0)} [options]"
      opts.separator ""
      opts.separator "Generate a comprehensive code review prompt from a diff file"
      opts.separator ""
      opts.separator "Examples:"
      opts.separator "  #{File.basename($0)} -d changes.diff"
      opts.separator "  #{File.basename($0)} -d changes.diff -o custom-prompt.md"
      opts.separator "  #{File.basename($0)} -d changes.diff --include-dependencies"
      opts.separator ""
      opts.separator "Options:"

      opts.on("-d", "--diff FILE", "Path to the diff file (required)") do |file|
        @options[:diff_file] = file
      end

      opts.on("-o", "--output FILE", "Output file for the prompt (optional)",
              "If not specified, generates: <diff-basename>-code-review-prompt.md") do |file|
        @options[:output_file] = file
      end

      opts.on("-r", "--root DIR", "Project root directory (default: current directory)") do |dir|
        @options[:project_root] = dir
      end

      opts.on("-i", "--include-dependencies", "Include project context and full dependencies",
              "Adds documentation files, ADRs, Gemfile, and gemspec content",
              "(default: minimal info for faster processing)") do
        @options[:include_dependencies] = true
      end

      opts.on("-v", "--verbose", "Show detailed progress information") do
        @options[:verbose] = true
      end

      opts.on("-h", "--help", "Show this help message") do
        puts opts
        exit
      end
    end.parse!
  end

  def validate_options
    unless @options[:diff_file]
      puts "Error: Diff file is required. Use -d or --diff to specify."
      puts "Run '#{File.basename($0)} --help' for usage examples."
      exit 1
    end

    unless File.exist?(@options[:diff_file])
      puts "Error: Diff file not found: #{@options[:diff_file]}"
      puts "Please check the file path and try again."
      exit 1
    end

    # Validate project root exists
    unless Dir.exist?(@options[:project_root])
      puts "Error: Project root directory not found: #{@options[:project_root]}"
      exit 1
    end

    # Auto-generate output file name if not provided
    unless @options[:output_file]
      diff_basename = File.basename(@options[:diff_file], '.*')
      diff_dir = File.dirname(@options[:diff_file])
      @options[:output_file] = File.join(diff_dir, "#{diff_basename}-code-review-prompt.md")
    end
  end

  def read_diff_file
    File.read(@options[:diff_file])
  rescue => e
    puts "Error reading diff file: #{e.message}"
    exit 1
  end

  def collect_project_state
    project_root = Pathname.new(@options[:project_root])

    state = {
      test_coverage: get_test_coverage(project_root),
      standardrb_status: get_standardrb_status(project_root),
      dependencies: get_dependencies(project_root)
    }

    # Add project context when include_dependencies is true
    if @options[:include_dependencies]
      state[:project_docs] = collect_project_docs(project_root)
      state[:adrs] = collect_adrs(project_root)
      state[:root_docs] = collect_root_docs(project_root)
      state[:gem_config] = collect_gem_config(project_root)
    end

    state
  end

  def get_test_coverage(project_root)
    log_verbose "Checking test coverage..."

    # Try to get coverage from HTML file
    coverage_html = project_root / 'coverage' / 'index.html'

    if coverage_html.exist?
      begin
        html_content = coverage_html.read

        # Extract coverage percentage (first percentage is overall coverage)
        percentages = html_content.scan(/(\d+\.?\d*)%/)
        coverage_percent = percentages.first&.first

        # Extract file count
        file_count = nil
        if html_content =~ /<b>(\d+)<\/b> files in total\./
          file_count = $1
        end

        # Extract line counts
        covered_lines = nil
        missed_lines = nil
        relevant_lines = nil

        if html_content =~ /<b>(\d+)<\/b> lines covered/
          covered_lines = $1
        end

        if html_content =~ /<b>(\d+)<\/b> lines missed/
          missed_lines = $1
        end

        if html_content =~ /<b>(\d+)<\/b> relevant lines/
          relevant_lines = $1
        end

        # Build coverage string
        if coverage_percent
          if covered_lines && relevant_lines && file_count
            return "#{coverage_percent}% (#{covered_lines}/#{relevant_lines} lines, #{file_count} files)"
          else
            return "#{coverage_percent}%"
          end
        end
      rescue => e
        log_verbose "Could not parse coverage HTML: #{e.message}"
      end
    end

    # Fallback to JSON file
    coverage_file = project_root / 'coverage' / '.last_run.json'
    if coverage_file.exist?
      begin
        data = JSON.parse(coverage_file.read)
        result = data.dig('result', 'line') || data.dig('result', 'covered_percent')
        return "#{result.round(2)}%" if result
      rescue => e
        log_verbose "Could not parse coverage JSON: #{e.message}"
      end
    end

    # Try running tests with coverage if not found
    if File.exist?(project_root / 'Rakefile') && system('which rake > /dev/null 2>&1')
      log_verbose "Running tests to get coverage..."
      output, = Open3.capture2e('rake spec', chdir: project_root.to_s)

      # Extract coverage from output
      if output =~ /Coverage report generated.*\((\d+\.?\d*)\%\)/
        return "#{$1}%"
      elsif output =~ /(\d+\.?\d*)\% coverage/
        return "#{$1}%"
      end
    end

    "Not available - run tests with coverage enabled"
  rescue => e
    log_verbose "Error getting coverage: #{e.message}"
    "Error retrieving coverage: #{e.message}"
  end

  def get_standardrb_status(project_root)
    log_verbose "Checking StandardRB status..."

    # Check if bin/lint exists
    bin_lint = project_root / 'bin' / 'lint'
    unless bin_lint.exist?
      return "No bin/lint script found"
    end

    # Check if bin/lint is executable
    unless bin_lint.executable?
      return "bin/lint script is not executable"
    end

    # Run bin/lint and capture output
    output, status = Open3.capture2e('./bin/lint', chdir: project_root.to_s)

    if status.success?
      "No offenses detected"
    else
      # Parse standardrb output for offense count
      lines = output.lines
      if summary_line = lines.find { |line| line =~ /\d+ file.* inspected.*\d+ offense/ }
        summary_line.strip
      elsif lines.any? { |line| line.include?('offenses detected') }
        offense_lines = lines.select { |line| line.include?('offenses detected') }
        offense_lines.first&.strip || "StandardRB found offenses"
      else
        "StandardRB found issues (#{lines.length} lines of output)"
      end
    end
  rescue => e
    log_verbose "Error running StandardRB: #{e.message}"
    "Error running StandardRB: #{e.message}"
  end

  def get_dependencies(project_root)
    log_verbose "Collecting gem dependencies..."

    gemfile = project_root / 'Gemfile'
    unless gemfile.exist?
      return ["No Gemfile found"]
    end

    dependencies = []
    current_group = :default

    gemfile.readlines.each do |line|
      line = line.strip

      # Track groups
      if line =~ /^group\s+:(\w+)/
        current_group = $1.to_sym
      elsif line =~ /^end/
        current_group = :default
      elsif line =~ /^gem\s+['"]([^'"]+)['"]/
        gem_name = $1
        version_match = line.match(/['"],\s*['"]([^'"]+)['"]/)
        version = version_match ? version_match[1] : 'any'

        if @options[:include_dependencies]
          group_str = current_group == :default ? '' : " (#{current_group})"
          dependencies << "- #{gem_name} #{version}#{group_str}"
        else
          dependencies << gem_name unless current_group == :development || current_group == :test
        end
      end
    end

    if @options[:include_dependencies]
      dependencies.empty? ? ["No dependencies found"] : dependencies
    else
      ["#{dependencies.count} runtime dependencies"]
    end
  rescue => e
    log_verbose "Error reading Gemfile: #{e.message}"
    ["Error reading Gemfile: #{e.message}"]
  end

  def collect_project_docs(project_root)
    log_verbose "Collecting project documentation..."
    docs_dir = project_root / 'docs-project'
    return ["No docs-project directory found"] unless docs_dir.exist?

    files = Dir.glob(docs_dir / '*.md').reject { |f| File.basename(f) == 'roadmap.md' }.sort
    if files.empty?
      ["No project documentation files found"]
    else
      files.map do |file|
        relative_path = Pathname.new(file).relative_path_from(project_root)
        content = File.read(file).strip
        "### #{relative_path}\n```markdown\n#{content}\n```"
      end
    end
  rescue => e
    ["Error collecting project docs: #{e.message}"]
  end

  def collect_adrs(project_root)
    log_verbose "Collecting ADRs..."

    # Collect from main decisions directory
    adr_files = []
    main_adr_dir = project_root / 'docs-project' / 'decisions'
    if main_adr_dir.exist?
      adr_files.concat(Dir.glob(main_adr_dir / '*.md'))
    end

    # Collect from current release directories
    current_pattern = project_root / 'docs-project' / 'current' / '*' / 'decisions' / '*.md'
    adr_files.concat(Dir.glob(current_pattern))

    # Remove duplicates and sort
    adr_files = adr_files.uniq.sort

    if adr_files.empty?
      ["No ADR files found"]
    else
      adr_files.map do |file|
        relative_path = Pathname.new(file).relative_path_from(project_root)
        content = File.read(file).strip
        "### #{relative_path}\n```markdown\n#{content}\n```"
      end
    end
  rescue => e
    ["Error collecting ADRs: #{e.message}"]
  end

  def collect_root_docs(project_root)
    log_verbose "Collecting root documentation..."
    files = Dir.glob(project_root / '*.md').sort
    if files.empty?
      ["No root documentation files found"]
    else
      files.map do |file|
        filename = File.basename(file)
        content = File.read(file).strip
        "### #{filename}\n```markdown\n#{content}\n```"
      end
    end
  rescue => e
    ["Error collecting root docs: #{e.message}"]
  end

  def collect_gem_config(project_root)
    log_verbose "Collecting gem configuration..."
    content_parts = []

    # Collect Gemfile
    gemfile = project_root / 'Gemfile'
    if gemfile.exist?
      content_parts << "### Gemfile\n```ruby\n#{gemfile.read.strip}\n```"
    else
      content_parts << "### Gemfile\nNo Gemfile found"
    end

    # Collect gemspec
    gemspec_files = Dir.glob(project_root / '*.gemspec')
    if gemspec_files.any?
      gemspec_files.each do |gemspec|
        basename = File.basename(gemspec)
        content_parts << "\n### #{basename}\n```ruby\n#{File.read(gemspec).strip}\n```"
      end
    else
      content_parts << "\n### Gemspec\nNo .gemspec file found"
    end

    content_parts.join("\n")
  rescue => e
    "Error collecting gem configuration: #{e.message}"
  end

  def log_verbose(message)
    puts "[DEBUG] #{message}" if @options[:verbose]
  end

  def build_prompt(diff_content, project_state)
    template = read_prompt_template

    prompt = template
      .gsub('[INSERT YOUR DIFF CONTENT HERE]', diff_content)
      .gsub('[INSERT CURRENT COVERAGE %]', project_state[:test_coverage])
      .gsub('[INSERT STANDARDRB STATUS]', project_state[:standardrb_status])
      .gsub('[LIST CURRENT GEMFILE DEPENDENCIES]', format_list(project_state[:dependencies]))

    # Add project context when available
    if @options[:include_dependencies]
      prompt = prompt
        .gsub('[LIST YOUR PROJECT DOCUMENTATION FILES HERE]', format_list(project_state[:project_docs]))
        .gsub('[LIST YOUR CURRENT ADR FILES HERE]', format_list(project_state[:adrs]))
        .gsub('[LIST YOUR ROOT MARKDOWN FILES HERE]', format_list(project_state[:root_docs]))
        .gsub('[INSERT GEMFILE AND GEMSPEC CONTENT HERE]', project_state[:gem_config])
    else
      # Provide minimal placeholders when not including dependencies
      prompt = prompt
        .gsub('[LIST YOUR PROJECT DOCUMENTATION FILES HERE]', '(Use --include-dependencies to include)')
        .gsub('[LIST YOUR CURRENT ADR FILES HERE]', '(Use --include-dependencies to include)')
        .gsub('[LIST YOUR ROOT MARKDOWN FILES HERE]', '(Use --include-dependencies to include)')
        .gsub('[INSERT GEMFILE AND GEMSPEC CONTENT HERE]', '(Use --include-dependencies to include)')
    end

    prompt
  end

  def read_prompt_template
    # Try multiple possible locations for the template
    possible_paths = [
      File.join(__dir__, '..', 'guides', 'code-review', '_code-review-from-diff.md'),
      File.join(@options[:project_root], 'docs-dev', 'guides', 'code-review', '_code-review-from-diff.md'),
      File.join(Dir.pwd, 'docs-dev', 'guides', 'code-review', '_code-review-from-diff.md')
    ]

    template_path = possible_paths.find { |path| File.exist?(path) }

    unless template_path
      puts "Error: Code review prompt template not found. Searched in:"
      possible_paths.each { |path| puts "  - #{path}" }
      puts ""
      puts "Make sure you're running from the project root or that the docs-dev"
      puts "directory structure is properly set up."
      exit 1
    end

    log_verbose "Using template: #{template_path}"
    File.read(template_path)
  rescue => e
    puts "Error reading prompt template: #{e.message}"
    exit 1
  end

  def format_list(items)
    return "None found" if items.empty?

    # For dependency lists, format as bullet points
    if items.first&.is_a?(String) && (items.first.include?('dependencies') || items.first.start_with?('-'))
      items.map { |item| item.start_with?('-') ? item : "- #{item}" }.join("\n")
    else
      # For content items (docs, ADRs), join with double newlines
      items.join("\n\n")
    end
  end

  def write_prompt_file(content)
    FileUtils.mkdir_p(File.dirname(@options[:output_file]))
    File.write(@options[:output_file], content)
    log_verbose "Wrote #{content.length} bytes to #{@options[:output_file]}"
  rescue => e
    puts "Error writing prompt file: #{e.message}"
    exit 1
  end
end

# Main execution
if __FILE__ == $0
  generator = CodeReviewPromptGenerator.new
  generator.generate
end
