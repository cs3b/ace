#!/usr/bin/env ruby
# get-recent-tasks: Summarize recently updated tasks (done/in-progress) from dev-taskflow
require 'optparse'
require 'yaml'
require 'time'

# Parse --last argument
def parse_last_arg(arg)
  case arg
  when /([0-9]+)\.(hour|hours)/
    $1.to_i * 3600
  when /([0-9]+)\.(day|days)/
    $1.to_i * 86400
  when /([0-9]+)\.(min|minute|minutes)/
    $1.to_i * 60
  else
    86400 # default 1 day
  end
end

opts = {}
OptionParser.new do |opt|
  opt.on('--last PERIOD', '-last PERIOD', 'Time window (e.g. 2.hours, 1.day)') { |v| opts[:last] = v }
end.parse!(ARGV)

since_seconds = parse_last_arg(opts[:last] || '1.day')
since_time = Time.now - since_seconds

# Find all relevant .md files
task_dirs = [
  'dev-taskflow/current',
  'dev-taskflow/done'
]
files = []
task_dirs.each do |dir|
  Dir.glob("#{dir}/**/tasks/*.md") { |f| files << f }
end

entries = []
files.each do |f|
  begin
    content = File.read(f)
    # Extract frontmatter (YAML between ---)
    if content =~ /^---\s*\n(.*?)\n---/m
      fm = YAML.safe_load($1)
      status = fm['status']
      id = fm['id']
      next unless status == 'done' || status == 'in-progress'
    else
      next
    end
    # Get last modified time
    mtime = File.mtime(f)
    next if mtime < since_time
    # Extract first header after frontmatter
    title = content.sub(/^---.*?---/m, '').match(/^#\s+(.+)/)&.captures&.first || '(No Title)'
    entries << {
      id: id,
      path: f,
      status: status,
      mtime: mtime,
      title: title
    }
  rescue => e
    warn "Error processing #{f}: #{e}"
  end
end

entries.sort_by! { |e| -e[:mtime].to_i }

puts "%-18s  %-8s  %-19s  %s" % ["Task ID", "Status", "Updated", "Title"]
puts "="*70
entries.each do |e|
  rel_path = e[:path].sub(/^.*dev-taskflow\//, 'dev-taskflow/')
  puts "%-18s  %-8s  %-19s  %s" % [e[:id], e[:status], e[:mtime].strftime('%Y-%m-%d %H:%M'), e[:title]]
  puts "    #{rel_path}"
end
