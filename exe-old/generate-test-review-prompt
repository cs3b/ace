    template_content
  end

  def format_test_docs(test_docs)
    return "No test documentation found" if test_docs.empty?

    test_docs.map do |doc|
      "#### #{doc[:path]}\n#{doc[:content]}"
    end.join("\n\n")
  end

  def format_spec_structure(spec_structure)
    return spec_structure if spec_structure.is_a?(String)

    <<~STRUCTURE
Total specs: #{spec_structure[:total]}
- Unit specs: #{spec_structure[:unit]}
- Integration specs: #{spec_structure[:integration]}
- Feature specs: #{spec_structure[:feature]}
- System specs: #{spec_structure[:system]}
    STRUCTURE
  end

  def format_test_helpers(helpers)
    return "No test helpers found" if helpers.empty?

    helpers.map { |h| "- #{h}" }.join("\n")
  end

  def format_implementation_files(impl_files)
    return "Implementation file tracking not requested" unless impl_files

    return "No spec files found in diff" if impl_files.empty?

    impl_files.map do |file_info|
      status = file_info[:exists] ? "✅ Found" : "❌ Not found"
      "- Spec: `#{file_info[:spec]}`\n  Implementation: `#{file_info[:implementation]}` (#{status})"
    end.join("\n\n")
  end

  def write_prompt_file(content)
    FileUtils.mkdir_p(File.dirname(@options[:output_file]))
    File.write(@options[:output_file], content)
  rescue => e
    puts "Error writing prompt file: #{e.message}"
    exit 1
  end
end

# Main execution
if __FILE__ == $0
  generator = TestReviewPromptGenerator.new
  generator.generate
end