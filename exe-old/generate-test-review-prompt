#!/usr/bin/env ruby
# frozen_string_literal: true

# Generate Test Review Prompt
# This script creates a comprehensive prompt for AI agents to review test/spec diffs
# with focus on RSpec best practices, test coverage, performance, and maintainability.
#
# Usage Examples:
#   Generate prompt from a diff file:
#     docs-dev/tools/generate-test-review-prompt -d changes.diff
#
#   Specify custom output location:
#     docs-dev/tools/generate-test-review-prompt -d changes.diff -o review-prompt.md
#
#   Include documentation context:
#     docs-dev/tools/generate-test-review-prompt -d changes.diff --include-docs
#
#   Include implementation files for coverage verification:
#     docs-dev/tools/generate-test-review-prompt -d changes.diff --include-implementation

require 'optparse'
require 'pathname'
require 'fileutils'

class TestReviewPromptGenerator
  def initialize
    @options = {
      diff_file: nil,
      output_file: nil,
      project_root: Dir.pwd,
      include_docs: false,
      include_implementation: false
    }

    parse_options
    validate_options
  end

  def generate
    puts "Generating test review prompt..."

    diff_content = read_diff_file
    test_context = collect_test_context

    prompt_content = build_prompt(diff_content, test_context)

    write_prompt_file(prompt_content)

    puts "Test review prompt generated: #{@options[:output_file]}"
    puts "Use this prompt with your AI agent to get comprehensive test review feedback."
  end

  private

  def parse_options
    OptionParser.new do |opts|
      opts.banner = "Usage: #{File.basename($0)} [options]"
      opts.separator ""
      opts.separator "Generate a comprehensive test review prompt from a diff file"
      opts.separator ""
      opts.separator "Examples:"
      opts.separator "  #{File.basename($0)} -d changes.diff"
      opts.separator "  #{File.basename($0)} -d changes.diff -o custom-prompt.md"
      opts.separator "  #{File.basename($0)} -d changes.diff --include-docs"
      opts.separator "  #{File.basename($0)} -d changes.diff --include-implementation"
      opts.separator ""
      opts.separator "Options:"

      opts.on("-d", "--diff FILE", "Path to the diff file (required)") do |file|
        @options[:diff_file] = file
      end

      opts.on("-o", "--output FILE", "Output file for the prompt (optional)",
              "If not specified, generates: <diff-basename>-test-review-prompt.md") do |file|
        @options[:output_file] = file
      end

      opts.on("-r", "--root DIR", "Project root directory (default: current directory)") do |dir|
        @options[:project_root] = dir
      end

      opts.on("-D", "--include-docs", "Include test documentation context",
              "(default: minimal context for faster processing)") do
        @options[:include_docs] = true
      end

      opts.on("-i", "--include-implementation", "Include implementation files to verify coverage",
              "(extracts tested files from spec paths)") do
        @options[:include_implementation] = true
      end

      opts.on("-h", "--help", "Show this help message") do
        puts opts
        exit
      end
    end.parse!
  end

  def validate_options
    unless @options[:diff_file]
      puts "Error: Diff file is required. Use -d or --diff to specify."
      puts "Run '#{File.basename($0)} --help' for usage examples."
      exit 1
    end

    unless File.exist?(@options[:diff_file])
      puts "Error: Diff file not found: #{@options[:diff_file]}"
      puts "Please check the file path and try again."
      exit 1
    end

    # Validate project root exists
    unless Dir.exist?(@options[:project_root])
      puts "Error: Project root directory not found: #{@options[:project_root]}"
      exit 1
    end

    # Auto-generate output file name if not provided
    unless @options[:output_file]
      diff_basename = File.basename(@options[:diff_file], '.*')
      diff_dir = File.dirname(@options[:diff_file])
      @options[:output_file] = File.join(diff_dir, "#{diff_basename}-test-review-prompt.md")
    end
  end

  def read_diff_file
    File.read(@options[:diff_file])
  rescue => e
    puts "Error reading diff file: #{e.message}"
    exit 1
  end

  def collect_test_context
    project_root = Pathname.new(@options[:project_root])

    context = {
      test_docs: collect_test_docs(project_root),
      spec_structure: analyze_spec_structure(project_root),
      test_helpers: collect_test_helpers(project_root)
    }

    if @options[:include_implementation]
      context[:implementation_files] = extract_implementation_files(@options[:diff_file], project_root)
    end

    context
  end

  def collect_test_docs(project_root)
    return [] unless @options[:include_docs]

    test_doc_paths = [
      project_root / 'docs' / 'testing.md',
      project_root / 'docs' / 'test-guidelines.md',
      project_root / 'spec' / 'README.md'
    ]

    test_doc_paths.select(&:exist?).map do |path|
      {
        path: path.relative_path_from(project_root).to_s,
        content: File.read(path).strip
      }
    end
  end

  def analyze_spec_structure(project_root)
    spec_dir = project_root / 'spec'
    return "No spec directory found" unless spec_dir.exist?

    # Count different types of specs
    unit_specs = Dir.glob(spec_dir / 'unit' / '**' / '*_spec.rb').size
    integration_specs = Dir.glob(spec_dir / 'integration' / '**' / '*_spec.rb').size
    feature_specs = Dir.glob(spec_dir / 'features' / '**' / '*_spec.rb').size
    system_specs = Dir.glob(spec_dir / 'system' / '**' / '*_spec.rb').size
    
    total_specs = Dir.glob(spec_dir / '**' / '*_spec.rb').reject { |f| f.include?('/cassettes/') }.size

    {
      total: total_specs,
      unit: unit_specs,
      integration: integration_specs,
      feature: feature_specs,
      system: system_specs
    }
  end

  def collect_test_helpers(project_root)
    spec_helper = project_root / 'spec' / 'spec_helper.rb'
    rails_helper = project_root / 'spec' / 'rails_helper.rb'
    support_files = Dir.glob(project_root / 'spec' / 'support' / '**' / '*.rb')

    helpers = []
    helpers << 'spec/spec_helper.rb' if spec_helper.exist?
    helpers << 'spec/rails_helper.rb' if rails_helper.exist?
    helpers += support_files.map { |f| Pathname.new(f).relative_path_from(project_root).to_s }

    helpers
  end

  def extract_implementation_files(diff_file, project_root)
    # Extract spec file paths from diff
    spec_files = []
    File.readlines(diff_file).each do |line|
      if line.match?(/^\+\+\+ b\/(.+_spec\.rb)$/) || line.match?(/^diff --git a\/(.+_spec\.rb)/)
        spec_files << $1
      end
    end

    # Map spec files to implementation files
    implementation_files = spec_files.map do |spec_file|
      impl_file = spec_file.gsub('/spec/', '/lib/').gsub('_spec.rb', '.rb')
      impl_path = project_root / impl_file
      
      if impl_path.exist?
        {
          spec: spec_file,
          implementation: impl_file,
          exists: true
        }
      else
        {
          spec: spec_file,
          implementation: impl_file,
          exists: false
        }
      end
    end

    implementation_files
  end

  def build_prompt(diff_content, test_context)
    template = read_prompt_template

    template
      .gsub('[INSERT YOUR DIFF CONTENT HERE]', diff_content)
      .gsub('[INSERT TEST DOCUMENTATION HERE]', format_test_docs(test_context[:test_docs]))
      .gsub('[INSERT SPEC STRUCTURE ANALYSIS HERE]', format_spec_structure(test_context[:spec_structure]))
      .gsub('[INSERT TEST HELPERS LIST HERE]', format_test_helpers(test_context[:test_helpers]))
      .gsub('[INSERT IMPLEMENTATION FILES HERE]', format_implementation_files(test_context[:implementation_files]))
  end

  def read_prompt_template
    template_content = <<~TEMPLATE
