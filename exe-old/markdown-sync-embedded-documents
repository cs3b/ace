#!/usr/bin/env ruby
# frozen_string_literal: true

# markdown-sync-embedded-documents: Synchronize XML-embedded template content
# =============================================================================
# Scans workflow instruction files for XML <templates> sections and synchronizes
# embedded template content with their corresponding template files.
#
# Usage:
#   markdown-sync-embedded-documents [options]
#
# Options:
#   --dry-run          Show what would be changed without modifying files
#   --verbose          Show detailed processing information
#   --path PATH        Directory to scan for workflow files (default: dev-handbook/workflow-instructions)
#   --commit           Automatically commit changes after synchronization
#   -h, --help         Show this help message
#
# Exit codes:
#   0  - Success (no errors, changes may or may not have been made)
#   1  - Error occurred during processing
#   2  - Invalid command-line arguments

require "optparse"
require "pathname"
require "fileutils"

class TemplateSync
  def initialize(options = {})
    @dry_run = options[:dry_run] || false
    @verbose = options[:verbose] || false
    @path = options[:path] || "dev-handbook/workflow-instructions"
    @commit = options[:commit] || false
    @changes_made = false
    @stats = {
      files_processed: 0,
      templates_synchronized: 0,
      templates_up_to_date: 0,
      errors: 0
    }
  end

  def run
    puts "#{@dry_run ? 'DRY RUN MODE - No files will be modified' : 'Synchronizing templates'}"
    puts "Scanning workflow files in: #{@path}"
    puts

    workflow_files = find_workflow_files(@path)
    
    if workflow_files.empty?
      puts "No workflow files found in #{@path}"
      return 0
    end

    puts "Found #{workflow_files.length} workflow files to process"
    puts

    workflow_files.each do |file_path|
      process_workflow_file(file_path)
    end

    print_summary
    
    if @commit && @changes_made && !@dry_run
      commit_changes
    end

    @stats[:errors] > 0 ? 1 : 0
  end

  private

  def find_workflow_files(base_path)
    pattern = File.join(base_path, "**/*.wf.md")
    debug("Scanning directory: #{base_path}")
    debug("Using pattern: #{pattern}")
    
    files = Dir.glob(pattern)
    debug("Found #{files.length} workflow files")
    files
  end

  def process_workflow_file(file_path)
    puts "Processing: #{File.basename(file_path)}"
    @stats[:files_processed] += 1

    begin
      content = File.read(file_path)
      templates = extract_templates(content)
      
      if templates.empty?
        info("  No templates found")
        return
      end

      debug("  Found #{templates.length} template(s)")
      
      updated_content = content
      file_changed = false

      templates.each do |template_info|
        result = process_template(template_info, file_path)
        case result[:status]
        when :updated
          updated_content = result[:content]
          file_changed = true
          puts "  ✅ Template synchronized: #{template_info[:path]}"
          @stats[:templates_synchronized] += 1
          @changes_made = true
        when :up_to_date
          puts "  ℹ️  Template up-to-date: #{template_info[:path]}"
          @stats[:templates_up_to_date] += 1
        when :error
          puts "  ❌ Error: #{result[:error]}"
          @stats[:errors] += 1
        end
      end

      if file_changed && !@dry_run
        File.write(file_path, updated_content)
        debug("  Wrote updated content to #{file_path}")
      end

    rescue => e
      puts "  ❌ Error processing file: #{e.message}"
      @stats[:errors] += 1
      debug("  Stack trace: #{e.backtrace.join("\n")}")
    end
  end

  def extract_templates(content)
    templates = []
    
    # Extract from new <documents> format
    content.scan(/<documents>(.*?)<\/documents>/m) do |documents_section|
      section_content = documents_section[0]
      
      # Process <template> tags
      section_content.scan(/<template\s+path="([^"]+)">(.*?)<\/template>/m) do |path, template_content|
        templates << {
          path: path,
          content: template_content,
          type: :template
        }
        debug("    Extracted template from <documents>: #{path}")
      end
      
      # Process <guide> tags
      section_content.scan(/<guide\s+path="([^"]+)">(.*?)<\/guide>/m) do |path, guide_content|
        templates << {
          path: path,
          content: guide_content,
          type: :guide
        }
        debug("    Extracted guide from <documents>: #{path}")
      end
    end
    
    # Extract from legacy <templates> format (backward compatibility)
    content.scan(/<templates>(.*?)<\/templates>/m) do |templates_section|
      section_content = templates_section[0]
      
      section_content.scan(/<template\s+path="([^"]+)">(.*?)<\/template>/m) do |path, template_content|
        templates << {
          path: path,
          content: template_content,
          type: :template
        }
        debug("    Extracted template from <templates>: #{path}")
      end
    end

    templates
  end

  def process_template(template_info, workflow_file_path)
    template_path = template_info[:path]
    embedded_content = template_info[:content]
    document_type = template_info[:type] || :template

    debug("    Processing #{document_type}: #{template_path}")

    # Validate document path based on type
    validation_result = validate_document_path(template_path, document_type)
    if validation_result[:error]
      return {
        status: :error,
        error: validation_result[:error]
      }
    end

    # Read template file
    begin
      file_content = File.read(template_path)
      debug("    Read template file: #{template_path} (#{file_content.length} chars)")
    rescue Errno::ENOENT
      return {
        status: :error,
        error: "Template file not found: #{template_path}"
      }
    rescue => e
      return {
        status: :error,
        error: "Failed to read template file #{template_path}: #{e.message}"
      }
    end

    # Compare content
    if content_differs?(embedded_content, file_content)
      debug("    Content differs, updating...")
      
      if @dry_run
        show_diff(embedded_content, file_content, template_path)
        return { status: :updated }
      else
        # Update the embedded content
        updated_content = update_embedded_document(
          File.read(workflow_file_path),
          template_path,
          file_content,
          document_type
        )
        return {
          status: :updated,
          content: updated_content
        }
      end
    else
      debug("    Content is up-to-date")
      return { status: :up_to_date }
    end
  end

  def content_differs?(embedded_content, file_content)
    # Normalize whitespace and line endings for comparison
    normalize_content(embedded_content) != normalize_content(file_content)
  end

  def normalize_content(content)
    # Remove leading/trailing whitespace and normalize line endings
    content.strip.gsub(/\r\n/, "\n")
  end

  def validate_document_path(path, document_type)
    case document_type
    when :template
      unless path.start_with?("dev-handbook/templates/") && path.end_with?(".template.md")
        return {
          error: "Invalid template path: #{path} (must be in dev-handbook/templates/ and end with .template.md)"
        }
      end
    when :guide
      unless path.start_with?("dev-handbook/guides/") && path.end_with?(".g.md")
        return {
          error: "Invalid guide path: #{path} (must be in dev-handbook/guides/ and end with .g.md)"
        }
      end
    else
      return {
        error: "Unknown document type: #{document_type}"
      }
    end
    
    { error: nil }
  end

  def update_embedded_document(workflow_content, document_path, new_content, document_type)
    # Replace the content between document tags while preserving XML structure
    
    escaped_path = Regexp.escape(document_path)
    
    # Try new <documents> format first
    if document_type == :template
      # Try <documents><template> format
      pattern = /(<documents>.*?<template\s+path="#{escaped_path}">)(.*?)(<\/template>.*?<\/documents>)/m
      if workflow_content.match(pattern)
        return workflow_content.gsub(pattern) { "#{$1}#{new_content}#{$3}" }
      end
    elsif document_type == :guide
      # Try <documents><guide> format
      pattern = /(<documents>.*?<guide\s+path="#{escaped_path}">)(.*?)(<\/guide>.*?<\/documents>)/m
      if workflow_content.match(pattern)
        return workflow_content.gsub(pattern) { "#{$1}#{new_content}#{$3}" }
      end
    end
    
    # Fall back to legacy <templates><template> format
    pattern = /(<template\s+path="#{escaped_path}">)(.*?)(<\/template>)/m
    workflow_content.gsub(pattern) { "#{$1}#{new_content}#{$3}" }
  end
  
  # Legacy method name for backward compatibility
  def update_embedded_template(workflow_content, template_path, new_content)
    update_embedded_document(workflow_content, template_path, new_content, :template)
  end

  def show_diff(embedded_content, file_content, template_path)
    puts "  📋 WOULD UPDATE: #{template_path}"
    puts "  "
    puts "  Differences found:"
    
    embedded_lines = embedded_content.split("\n")
    file_lines = file_content.split("\n")
    
    max_lines = [embedded_lines.length, file_lines.length].max
    
    (0...max_lines).each do |i|
      old_line = embedded_lines[i] || ""
      new_line = file_lines[i] || ""
      
      if old_line != new_line
        puts "  - Line #{i + 1}: [OLD] #{old_line}"
        puts "  + Line #{i + 1}: [NEW] #{new_line}"
      end
    end
    puts
  end

  def print_summary
    puts
    puts "Summary:"
    puts "  Files processed: #{@stats[:files_processed]}"
    
    if @dry_run
      puts "  Would synchronize: #{@stats[:templates_synchronized]} template#{@stats[:templates_synchronized] == 1 ? '' : 's'}"
      puts "  Would skip: #{@stats[:templates_up_to_date]} template#{@stats[:templates_up_to_date] == 1 ? '' : 's'} (up-to-date)"
    else
      puts "  Templates synchronized: #{@stats[:templates_synchronized]}"
      puts "  Templates up-to-date: #{@stats[:templates_up_to_date]}"
    end
    
    if @stats[:errors] > 0
      puts "  Errors: #{@stats[:errors]}"
    end
    puts
  end

  def commit_changes
    puts "Committing changes..."
    
    # Check if we're in a git repository
    unless system("git rev-parse --git-dir > /dev/null 2>&1")
      puts "  ❌ Error: Not in a git repository"
      return
    end

    # Add changed files
    system("git add -A")
    
    # Create commit message
    commit_message = "chore: sync embedded templates\n\n"
    if @stats[:templates_synchronized] > 0
      commit_message += "- Synchronized #{@stats[:templates_synchronized]} template#{@stats[:templates_synchronized] == 1 ? '' : 's'}"
      if @stats[:templates_up_to_date] > 0
        commit_message += ", #{@stats[:templates_up_to_date]} up-to-date"
      end
      commit_message += "\n\n"
    end
    commit_message += "🤖 Generated with [Claude Code](https://claude.ai/code)\n\n"
    commit_message += "Co-Authored-By: Claude <noreply@anthropic.com>"

    # Commit changes
    if system("git", "commit", "-m", commit_message)
      puts "  ✅ Changes committed successfully"
    else
      puts "  ❌ Error committing changes"
    end
  end

  def debug(message)
    puts message if @verbose
  end

  def info(message)
    puts message
  end
end

# Command-line option parsing
def parse_options
  options = {}
  
  OptionParser.new do |opts|
    opts.banner = "Usage: markdown-sync-embedded-documents [options]"
    opts.separator ""
    opts.separator "Synchronizes XML-embedded template content in workflow instructions"
    opts.separator "with their corresponding template files."
    opts.separator ""
    opts.separator "Options:"

    opts.on("--dry-run", "Show what would be changed without modifying files") do
      options[:dry_run] = true
    end

    opts.on("--verbose", "Show detailed processing information") do
      options[:verbose] = true
    end

    opts.on("--path PATH", "Directory to scan (default: dev-handbook/workflow-instructions)") do |path|
      options[:path] = path
    end

    opts.on("--commit", "Automatically commit changes after synchronization") do
      options[:commit] = true
    end

    opts.on("-h", "--help", "Show this help message") do
      puts opts
      exit 0
    end

    opts.separator ""
    opts.separator "Examples:"
    opts.separator "  markdown-sync-embedded-documents                    # Sync all templates"
    opts.separator "  markdown-sync-embedded-documents --dry-run          # Preview changes"
    opts.separator "  markdown-sync-embedded-documents --verbose --commit # Sync with detailed output and auto-commit"
    opts.separator ""
  end.parse!

  options
end

# Main execution
if __FILE__ == $0
  begin
    options = parse_options
    sync = TemplateSync.new(options)
    exit_code = sync.run
    exit(exit_code)
  rescue OptionParser::InvalidOption => e
    puts "Error: #{e.message}"
    puts "Use --help for usage information"
    exit 2
  rescue Interrupt
    puts "\nInterrupted by user"
    exit 1
  rescue => e
    puts "Unexpected error: #{e.message}"
    puts e.backtrace if ENV['DEBUG']
    exit 1
  end
end