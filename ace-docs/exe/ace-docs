#!/usr/bin/env ruby
# frozen_string_literal: true

require "thor"
require_relative "../lib/ace/docs"

module Ace
  module Docs
    class CLI < Thor
      desc "status", "Show status of all managed documents"
      option :type, desc: "Filter by document type"
      option :needs_update, type: :boolean, desc: "Show only documents needing update"
      option :freshness, desc: "Filter by freshness status (current/stale/outdated)"
      def status
        require_relative "../lib/ace/docs/commands/status_command"
        Commands::StatusCommand.new(options).execute
      rescue StandardError => e
        error_exit("Error showing status", e)
      end

      desc "discover", "Find and list all managed documents"
      def discover
        require_relative "../lib/ace/docs/organisms/document_registry"
        registry = Organisms::DocumentRegistry.new
        documents = registry.all

        if documents.empty?
          puts "No managed documents found."
          return
        end

        puts "Found #{documents.size} managed documents:"
        documents.each do |doc|
          puts "  #{doc.relative_path || doc.path} (#{doc.doc_type})"
        end
      rescue StandardError => e
        error_exit("Error discovering documents", e)
      end

      desc "diff [FILE]", "Analyze changes for documents"
      option :all, type: :boolean, desc: "Analyze all managed documents"
      option :needs_update, type: :boolean, desc: "Analyze documents needing update"
      option :since, desc: "Date or commit to diff from"
      option :exclude_renames, type: :boolean, desc: "Exclude renamed files"
      option :exclude_moves, type: :boolean, desc: "Exclude moved files"
      def diff(file = nil)
        require_relative "../lib/ace/docs/commands/diff_command"
        exit_code = Commands::DiffCommand.new(options).execute(file)
        exit(exit_code) if exit_code != 0
      end

      desc "update FILE", "Update document frontmatter"
      option :set, type: :hash, desc: "Fields to update (e.g., --set last-updated=today)"
      option :preset, desc: "Update all documents matching preset"
      def update(file = nil)
        require_relative "../lib/ace/docs/commands/update_command"
        exit_code = Commands::UpdateCommand.new(options).execute(file)
        exit(exit_code) if exit_code != 0
      end

      desc "analyze [FILES...]", "Batch analyze documents with LLM compaction"
      option :needs_update, type: :boolean, desc: "Analyze documents needing updates"
      option :type, desc: "Filter by document type"
      option :freshness, desc: "Filter by freshness (current/stale/outdated)"
      option :since, desc: "Override time range (e.g., '1 week ago')"
      option :exclude_renames, type: :boolean, desc: "Exclude renamed files from diff"
      option :exclude_moves, type: :boolean, desc: "Exclude moved files from diff"
      option :output, desc: "Output format: compact|detailed (default: compact)"
      def analyze(*files)
        require_relative "../lib/ace/docs/commands/analyze_command"
        exit_code = Commands::AnalyzeCommand.new(options).execute(*files)
        exit(exit_code) if exit_code != 0
      end

      desc "validate [FILE|PATTERN]", "Validate documents against rules"
      option :syntax, type: :boolean, desc: "Run syntax validation using linters"
      option :semantic, type: :boolean, desc: "Run semantic validation using LLM"
      option :all, type: :boolean, desc: "Run all validation types"
      def validate(pattern = nil)
        require_relative "../lib/ace/docs/commands/validate_command"
        exit_code = Commands::ValidateCommand.new(options).execute(pattern)
        exit(exit_code) if exit_code != 0
      end

      desc "version", "Show ace-docs version"
      def version
        puts "ace-docs version #{Ace::Docs::VERSION}"
      end

      private

      def error_exit(message, exception = nil)
        puts "Error: #{message}".red
        puts "  #{exception.message}".red if exception && ENV["DEBUG"]
        puts "  #{exception.backtrace.join("\n  ")}".red if exception && ENV["TRACE"]
        exit 1
      end
    end
  end
end

Ace::Docs::CLI.start(ARGV)