#!/usr/bin/env ruby
# frozen_string_literal: true

require 'ace/context'
require 'optparse'

options = {
  format: 'markdown-xml',
  max_size: 1_048_576,
  timeout: 30,
  debug: false
}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: context [INPUTS...] [options]"

  opts.on("-p", "--preset NAME1,NAME2", Array, "Load context from preset(s) (comma-separated)") do |p|
    options[:preset] = p
  end

  opts.on("-f", "--file FILE", "Load context from file") do |f|
    options[:file] = f
  end

  opts.on("-l", "--list", "--list-presets", "List available presets") do
    options[:list] = true
  end

  opts.on("-c", "--cache [PATH]", "Cache output to file (default: .cache/ace-context/preset.md)") do |path|
    options[:cache] = path || true
  end

  opts.on("-n", "--no-cache", "Output to stdout without caching") do
    options[:no_cache] = true
  end

  opts.on("--format FORMAT", %w[markdown yaml xml markdown-xml json],
          "Output format (default: markdown-xml)") do |f|
    options[:format] = f
  end

  opts.on("--max-size BYTES", Integer, "Maximum file size in bytes (default: 1MB)") do |size|
    options[:max_size] = size
  end

  opts.on("--timeout SECONDS", Integer, "Command timeout in seconds (default: 30)") do |t|
    options[:timeout] = t
  end

  opts.on("-d", "--debug", "Enable debug output") do
    options[:debug] = true
  end

  opts.on("-h", "--help", "Show this help message") do
    puts opts
    puts
    puts "Examples:"
    puts "  context templates/project-essentials.yaml"
    puts "  context .claude/agents/task-manager.ag.md"
    puts "  context 'files: [docs/*.md]'"
    puts "  context templates/project.yaml --format xml"
    puts "  context --preset project                    # Caches to .cache/ace-context/project.md"
    puts "  context --preset project --cache custom.md  # Caches to custom.md"
    puts "  context --preset project --no-cache         # Outputs to stdout"
    puts "  context --preset project,dev-tools          # Caches merged output"
    puts "  context --list-presets"
    exit
  end
end

parser.parse!

# Validate conflicting options
if options[:cache] && options[:no_cache]
  $stderr.puts "Error: Cannot use both --cache and --no-cache options"
  exit 1
end

# Handle list presets
if options[:list]
  presets = Ace::Context.list_presets
  if presets.empty?
    puts "No presets configured in .ace/context.yml"
    puts "Looking for .coding-agent/context.yml for backward compatibility..."

    # Check for backward compatible config
    presets = Ace::Context.list_presets(config_path: '.coding-agent/context.yml')
    if presets.empty?
      puts "No presets found in either location"
    else
      puts "Found presets in .coding-agent/context.yml:"
    end
  else
    puts "Available presets:"
  end

  presets.each do |preset|
    puts "  #{preset[:name]}"
    puts "    Description: #{preset[:description]}" if preset[:description]
    puts "    Template:    #{preset[:template]}" if preset[:template]
    puts "    Cache path:  #{preset[:output]}" if preset[:output]
    puts "    Chunk limit: #{preset[:chunk_limit]} lines" if preset[:chunk_limit]
    puts
  end
  exit
end

# Determine inputs
inputs = ARGV.dup

# Handle different loading scenarios
if options[:preset]
  # Multiple preset support
  if options[:preset].is_a?(Array) && options[:preset].size > 1
    context = Ace::Context.load_multiple_presets(options[:preset], options)
  else
    preset_name = options[:preset].is_a?(Array) ? options[:preset].first : options[:preset]
    context = Ace::Context.load_preset(preset_name, options)
  end
elsif options[:file]
  context = Ace::Context.load_file(options[:file], options)
elsif inputs.any?
  # Handle multiple inputs
  if inputs.size == 1
    # Auto-detect single input
    context = Ace::Context.load_auto(inputs.first, options)
  else
    context = Ace::Context.load_multiple(inputs, options)
  end
else
  # Default to 'default' or 'project' preset
  context = Ace::Context.load_preset('project', options) ||
            Ace::Context.load_preset('default', options)

  unless context
    $stderr.puts "Error: No inputs specified and no default preset found"
    $stderr.puts "Use --help for usage information"
    exit 1
  end
end

# Handle output
if context.metadata[:error]
  $stderr.puts "Error: #{context.metadata[:error]}"
  $stderr.puts context.metadata[:errors].join("\n") if context.metadata[:errors] && options[:debug]
  exit 1
else
  # Determine output path based on cache options
  if options[:no_cache]
    # Output to stdout only
    puts context.content
  else
    # Cache is enabled (default behavior)
    cache_path = nil

    if options[:cache] == true || options[:cache].nil?
      # Use default cache location
      preset_name = if options[:preset]
        if options[:preset].is_a?(Array)
          options[:preset].join('-')
        else
          options[:preset]
        end
      elsif inputs.any?
        # Generate cache name from input
        File.basename(inputs.first, '.*')
      else
        'context'
      end

      # Sanitize preset name for filename
      safe_name = preset_name.gsub(/[^a-z0-9_-]/i, '-')
      cache_path = ".cache/ace-context/#{safe_name}.md"
    else
      # Use specified cache path
      cache_path = options[:cache]
    end

    # Create cache directory if needed
    require 'fileutils'
    cache_dir = File.dirname(cache_path)
    FileUtils.mkdir_p(cache_dir) unless File.directory?(cache_dir)

    # Write to cache file
    result = Ace::Context.write_output(context, cache_path, options)

    if result[:success]
      if result[:chunked]
        puts "Context cached (#{result[:total_chunks]} chunks, #{result[:files_written]} files)"
        puts "Index file: #{result[:index_file]}"
      else
        puts "Context cached to #{cache_path}"
        puts "  Lines: #{result[:lines]}"
        puts "  Size: #{result[:size_formatted]}"
      end
    else
      $stderr.puts "Error writing cache: #{result[:error]}"
      exit 1
    end
  end
end