#!/usr/bin/env ruby
# frozen_string_literal: true

require 'ace/context'
require 'ace/context/atoms/line_counter'
require 'optparse'

options = {
  format: 'markdown-xml',
  max_size: 1_048_576,
  timeout: 30,
  debug: false,
  output: nil,  # Will be determined from preset or CLI
  presets: [],  # Array to collect multiple presets
  files: [],    # Array to collect file paths
  inspect_config: false,  # Configuration inspection mode
  embed_source: false,  # Embed source document in output
}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: ace-context [INPUT] [options]"

  opts.separator ""
  opts.separator "INPUT can be:"
  opts.separator "  - Preset name (e.g., 'project', 'base')"
  opts.separator "  - File path (e.g., '/path/to/config.yml', './context.md')"
  opts.separator "  - Protocol URL (e.g., 'wfi://workflow', 'guide://testing')"
  opts.separator ""
  opts.separator "Options:"

  opts.on("-p", "--preset NAME", "Load context from preset (can be used multiple times)") do |p|
    options[:presets] << p
  end

  opts.on("--presets NAMES", "Load multiple presets (comma-separated list)") do |presets|
    options[:presets].concat(presets.split(',').map(&:strip))
  end

  opts.on("-f", "--file FILE", "Load context from file (YAML or markdown with frontmatter, can be used multiple times)") do |file|
    options[:files] << file
  end

  opts.on("--inspect-config", "Show merged configuration without loading files or executing commands") do
    options[:inspect_config] = true
  end

  opts.on("-e", "--embed-source", "Embed source document in output (overrides frontmatter setting)") do
    options[:embed_source] = true
  end

  opts.on("-l", "--list", "--list-presets", "List available presets") do
    options[:list] = true
  end

  opts.on("-o", "--output MODE", "Output mode: stdio, cache, or file path (default: preset default or stdio)") do |output|
    options[:output] = output
  end

  opts.on("--format FORMAT", %w[markdown yaml xml markdown-xml json],
          "Output format (default: markdown-xml)") do |f|
    options[:format] = f
  end

  opts.on("--max-size BYTES", Integer, "Maximum file size in bytes (default: 1MB)") do |size|
    options[:max_size] = size
  end

  opts.on("--timeout SECONDS", Integer, "Command timeout in seconds (default: 30)") do |t|
    options[:timeout] = t
  end

  opts.on("-d", "--debug", "Enable debug output") do
    options[:debug] = true
  end

  opts.on("-h", "--help", "Show this help message") do
    puts opts
    puts
    puts "Examples:"
    puts "  ace-context                          # Load default preset"
    puts "  ace-context project                  # Load project preset"
    puts "  ace-context /path/to/config.yml      # Load configuration file (auto-detected)"
    puts "  ace-context ./context.md             # Load markdown with frontmatter (auto-detected)"
    puts "  ace-context wfi://create-task        # Load via protocol URL"
    puts "  ace-context -p base -p custom        # Load and merge multiple presets"
    puts "  ace-context --presets base,team      # Load multiple presets (comma-separated)"
    puts "  ace-context -f config.yml             # Explicitly load from file"
    puts "  ace-context -f config1.yml -f config2.md  # Load multiple files"
    puts "  ace-context -p base -f custom.yml    # Mix presets and files"
    puts "  ace-context /path/to/config.yml --inspect-config  # Inspect file configuration"
    puts "  ace-context -p base --inspect-config # Show merged config without execution"
    puts "  ace-context project --output stdio   # Output to stdout"
    puts "  ace-context project --output cache   # Save to cache"
    puts "  ace-context project --output ./custom.md  # Save to file"
    puts "  ace-context --embed-source           # Embed source document in output"
    puts "  ace-context -e ./prompt.md           # Short form of --embed-source"
    puts "  ace-context --list-presets           # List available presets"
    puts
    puts "Output modes:"
    puts "  stdio - Output to stdout"
    puts "  cache - Save to .cache/ace-context/[preset].md"
    puts "  [path] - Save to specified file path"
    exit
  end
end

parser.parse!

# Handle list presets
if options[:list]
  presets = Ace::Context.list_presets
  if presets.empty?
    puts "No presets found in .ace/context/presets/"
    puts "Create markdown files with YAML frontmatter in .ace/context/presets/ to define presets."
    puts "Example presets are available in the ace-context gem at .ace-defaults/context/"
  else
    puts "Available presets:"
    presets.each do |preset|
      puts "  #{preset[:name]}"
      puts "    Description: #{preset[:description]}" if preset[:description]
      puts "    Default output: #{preset[:output] || 'stdio'}"
      puts "    Source: #{preset[:source_file]}" if preset[:source_file]
      puts
    end
  end
  exit
end

# Determine input (preset name, file path, or protocol)
# Handle configuration inspection mode
if options[:inspect_config]
  # Inspect configuration mode
  inputs = []
  inputs.concat(options[:presets]) if options[:presets].any?
  inputs.concat(options[:files]) if options[:files].any?
  inputs << ARGV[0] if ARGV[0] && inputs.empty?
  inputs << 'default' if inputs.empty?

  context = Ace::Context.inspect_config(inputs, options)
  input = inputs.join('-')  # For cache filename generation
elsif options[:presets].any? || options[:files].any?
  # Multi-input mode (presets and/or files)
  inputs = []

  # Maintain order of specification by processing both arrays
  # This allows mixing: -p preset1 -f file1 -p preset2
  context = Ace::Context.load_multiple_inputs(options[:presets], options[:files], options)

  # Create input string for cache filename
  all_inputs = options[:presets] + options[:files].map { |f| File.basename(f, '.*') }
  input = all_inputs.join('-')
elsif ARGV[0]
  # Single input from argument
  input = ARGV[0]
  context = Ace::Context.load_auto(input, options)
else
  # Default preset
  input = 'default'
  context = Ace::Context.load_auto(input, options)
end

# Handle errors
if context.metadata[:error]
  $stderr.puts "Error: #{context.metadata[:error]}"
  $stderr.puts context.metadata[:errors].join("\n") if context.metadata[:errors] && options[:debug]
  exit 1
end

# Determine output mode
# Priority: CLI flag > preset metadata > auto-format based on line count
explicit_output = options[:output] || context.metadata[:output]

if explicit_output
  # Explicit output mode specified - honor it
  output_mode = explicit_output
else
  # Auto-format: decide based on line count vs threshold
  line_count = Ace::Context::Atoms::LineCounter.count(context.content)
  threshold = Ace::Context.auto_format_threshold

  output_mode = line_count >= threshold ? 'cache' : 'stdio'
end

# Handle output based on mode
case output_mode
when 'stdio'
  # Output to stdout
  puts context.content
when 'cache'
  # Save to cache directory
  require 'fileutils'
  require 'ace/support/fs'
  project_root = Ace::Support::Fs::Molecules::ProjectRootFinder.find_or_current
  cache_dir = File.join(project_root, '.cache/ace-context')
  FileUtils.mkdir_p(cache_dir)

  # Generate cache filename from input (preset name, protocol, or sanitized file path)
  cache_name = input.gsub(/[^a-zA-Z0-9-]/, '_')
  cache_file = File.join(cache_dir, "#{cache_name}.md")
  result = Ace::Context.write_output(context, cache_file, options)

  if result[:success]
    puts "Context saved (#{result[:lines]} lines, #{result[:size_formatted]}), output file:"
    puts cache_file
  else
    $stderr.puts "Error writing cache: #{result[:error]}"
    exit 1
  end
else
  # Save to specified file path
  require 'fileutils'
  output_dir = File.dirname(output_mode)
  FileUtils.mkdir_p(output_dir) unless output_dir == '.'

  result = Ace::Context.write_output(context, output_mode, options)

  if result[:success]
    puts "Context saved (#{result[:lines]} lines, #{result[:size_formatted]}), output file:"
    puts output_mode
  else
    $stderr.puts "Error writing file: #{result[:error]}"
    exit 1
  end
end