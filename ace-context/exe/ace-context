#!/usr/bin/env ruby
# frozen_string_literal: true

require 'ace/context'
require 'optparse'

options = {
  format: 'markdown-xml',
  max_size: 1_048_576,
  timeout: 30,
  debug: false,
  output: nil  # Will be determined from preset or CLI
}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: ace-context [PRESET] [options]"

  opts.on("-p", "--preset NAME", "Load context from preset") do |p|
    options[:preset] = p
  end

  opts.on("-l", "--list", "--list-presets", "List available presets") do
    options[:list] = true
  end

  opts.on("-o", "--output MODE", "Output mode: stdio, cache, or file path (default: preset default or stdio)") do |output|
    options[:output] = output
  end

  opts.on("--format FORMAT", %w[markdown yaml xml markdown-xml json],
          "Output format (default: markdown-xml)") do |f|
    options[:format] = f
  end

  opts.on("--max-size BYTES", Integer, "Maximum file size in bytes (default: 1MB)") do |size|
    options[:max_size] = size
  end

  opts.on("--timeout SECONDS", Integer, "Command timeout in seconds (default: 30)") do |t|
    options[:timeout] = t
  end

  opts.on("-d", "--debug", "Enable debug output") do
    options[:debug] = true
  end

  opts.on("-h", "--help", "Show this help message") do
    puts opts
    puts
    puts "Examples:"
    puts "  ace-context                          # Load default preset"
    puts "  ace-context project                  # Load project preset"
    puts "  ace-context project --output stdio   # Output to stdout"
    puts "  ace-context project --output cache   # Save to cache"
    puts "  ace-context project --output ./custom.md  # Save to file"
    puts "  ace-context --list-presets           # List available presets"
    puts
    puts "Output modes:"
    puts "  stdio - Output to stdout"
    puts "  cache - Save to .cache/ace-context/[preset].md"
    puts "  [path] - Save to specified file path"
    exit
  end
end

parser.parse!

# Handle list presets
if options[:list]
  presets = Ace::Context.list_presets
  if presets.empty?
    puts "No presets found in .ace/context/presets/"
    puts "Create markdown files with YAML frontmatter in .ace/context/presets/ to define presets."
    puts "Example presets are available in the ace-context gem at .ace.example/context/"
  else
    puts "Available presets:"
    presets.each do |preset|
      puts "  #{preset[:name]}"
      puts "    Description: #{preset[:description]}" if preset[:description]
      puts "    Default output: #{preset[:output] || 'stdio'}"
      puts "    Source: #{preset[:source_file]}" if preset[:source_file]
      puts
    end
  end
  exit
end

# Determine input (preset name, file path, or protocol)
input = options[:preset] || ARGV[0] || 'default'

# Load the context (auto-detect: preset, file, protocol, or inline YAML)
context = Ace::Context.load_auto(input, options)

# Handle errors
if context.metadata[:error]
  $stderr.puts "Error: #{context.metadata[:error]}"
  $stderr.puts context.metadata[:errors].join("\n") if context.metadata[:errors] && options[:debug]
  exit 1
end

# Determine output mode
output_mode = options[:output] || context.metadata[:output] || 'stdio'

# Handle output based on mode
case output_mode
when 'stdio'
  # Output to stdout
  puts context.content
when 'cache'
  # Save to cache directory
  require 'fileutils'
  require 'ace/core/molecules/project_root_finder'
  project_root = Ace::Core::Molecules::ProjectRootFinder.find_or_current
  cache_dir = File.join(project_root, '.cache/ace-context')
  FileUtils.mkdir_p(cache_dir)

  # Generate cache filename from input (preset name, protocol, or sanitized file path)
  cache_name = input.gsub(/[^a-zA-Z0-9-]/, '_')
  cache_file = File.join(cache_dir, "#{cache_name}.md")
  result = Ace::Context.write_output(context, cache_file, options)

  if result[:success]
    puts "Context saved (#{result[:lines]} lines, #{result[:size_formatted]}), output file:"
    puts cache_file
  else
    $stderr.puts "Error writing cache: #{result[:error]}"
    exit 1
  end
else
  # Save to specified file path
  require 'fileutils'
  output_dir = File.dirname(output_mode)
  FileUtils.mkdir_p(output_dir) unless output_dir == '.'

  result = Ace::Context.write_output(context, output_mode, options)

  if result[:success]
    puts "Context saved (#{result[:lines]} lines, #{result[:size_formatted]}), output file:"
    puts output_mode
  else
    $stderr.puts "Error writing file: #{result[:error]}"
    exit 1
  end
end