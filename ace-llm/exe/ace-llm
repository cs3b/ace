#!/usr/bin/env ruby
# frozen_string_literal: true

# Add lib directory to load path if running from development
lib_path = File.expand_path("../lib", __dir__)
$LOAD_PATH.unshift(lib_path) if File.directory?(lib_path)

# Add ace-support-core lib if in development mode
ace_support_core_lib = File.expand_path("../../ace-support-core/lib", __dir__)
$LOAD_PATH.unshift(ace_support_core_lib) if File.directory?(ace_support_core_lib)

# Load .env files from .ace cascade (if ace-support-core is available)
require "ace/llm"
Ace::LLM::Atoms::EnvReader.load_env_cascade

# No args → show help
args = ARGV.empty? ? ["--help"] : ARGV

# Start ace-support-cli single-command entrypoint with exception-based exit code handling (per ADR-023)
begin
  Ace::Support::Cli::Runner.new(Ace::LLM::CLI::Commands::Query).call(args: args)
rescue Ace::Core::CLI::Error => e
  warn e.message
  exit(e.exit_code)
end
