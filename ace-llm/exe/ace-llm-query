#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require "pathname"

# Add lib directory to load path if running from development
lib_path = File.expand_path("../lib", __dir__)
$LOAD_PATH.unshift(lib_path) if File.directory?(lib_path)

# Add ace-core lib if in development mode
ace_core_lib = File.expand_path("../../ace-core/lib", __dir__)
$LOAD_PATH.unshift(ace_core_lib) if File.directory?(ace_core_lib)

require "ace/llm"
require "ace/llm/molecules/client_registry"

# Load .env files from .ace cascade (if ace-core is available)
Ace::LLM::Atoms::EnvReader.load_env_cascade

module Ace
  module LLM
    # CLI for ace-llm-query command
    class QueryCLI
      def initialize
        @options = {
          format: "text",
          temperature: nil,
          max_tokens: nil,
          system: nil,
          timeout: 30,
          force: false,
          debug: false,
          list_providers: false,
          model: nil,
          prompt: nil
        }
        @registry = Molecules::ClientRegistry.new
      end

      def run(args)
        parse_arguments(args)

        # Handle special commands
        if @options[:list_providers]
          list_providers
          exit(0)
        end

        execute_query
      rescue Ace::LLM::Error => e
        error_output(e.message)
        exit(1)
      rescue StandardError => e
        if @options[:debug]
          error_output("Error: #{e.class}: #{e.message}")
          error_output(e.backtrace.join("\n"))
        else
          error_output("Error: #{e.message}")
          error_output("Use --debug for more information")
        end
        exit(1)
      end

      private

      def parse_arguments(args)
        parser = create_option_parser

        # Parse options
        remaining_args = parser.parse(args)

        # Check if we're just listing providers
        if @options[:list_providers]
          return # Return early for list-providers
        end

        # Extract provider_model and prompt from remaining args
        if remaining_args.empty?
          puts parser
          exit(0)
        end

        @provider_model = remaining_args.shift
        positional_prompt = remaining_args.join(" ")

        # Resolve prompt: --prompt flag > positional argument
        @prompt = @options[:prompt] || positional_prompt

        # If no prompt provided from any source, show help for the provider
        if @prompt.nil? || @prompt.empty?
          show_provider_help
          exit(0)
        end
      rescue OptionParser::InvalidOption => e
        error_output(e.message)
        puts parser
        exit(1)
      end

      def create_option_parser
        OptionParser.new do |opts|
          opts.banner = "Usage: ace-llm-query PROVIDER[:MODEL] [PROMPT] [options]\n" \
                        "       ace-llm-query PROVIDER --prompt PROMPT [options]\n" \
                        "       ace-llm-query PROVIDER PROMPT --model MODEL [options]"
          opts.separator ""
          opts.separator "Query any LLM provider through a unified interface"
          opts.separator ""
          opts.separator "Options:"

          opts.on("-o", "--output FILE", "Output file path") do |file|
            @options[:output] = file
          end

          opts.on("-f", "--format FORMAT", ["text", "json", "markdown"],
                  "Output format (text, json, markdown)") do |format|
            @options[:format] = format
          end

          opts.on("-t", "--temperature FLOAT", Float, "Temperature (0.0-2.0)") do |temp|
            @options[:temperature] = temp
          end

          opts.on("-m", "--max-tokens INT", Integer, "Maximum output tokens") do |tokens|
            @options[:max_tokens] = tokens
          end

          opts.on("-s", "--system TEXT", "System instruction/prompt") do |system|
            @options[:system] = system
          end

          opts.on("--timeout SECONDS", Integer, "Request timeout in seconds") do |timeout|
            @options[:timeout] = timeout
          end

          opts.on("--model MODEL", "Model name (overrides PROVIDER[:MODEL] if both present)") do |model|
            @options[:model] = model
          end

          opts.on("--prompt PROMPT", "Prompt text (overrides positional PROMPT if both present)") do |prompt|
            @options[:prompt] = prompt
          end

          opts.on("--force", "Force overwrite existing files") do
            @options[:force] = true
          end

          opts.on("-d", "--debug", "Enable debug output") do
            @options[:debug] = true
          end

          opts.on("-h", "--help", "Show this help message") do
            puts opts
            exit(0)
          end

          opts.on("-v", "--version", "Show version") do
            puts "ace-llm-query #{Ace::LLM::VERSION}"
            exit(0)
          end

          opts.on("--list-providers", "List available providers and their status") do
            @options[:list_providers] = true
          end

          opts.separator ""
          opts.separator "Examples:"
          opts.separator '  ace-llm-query google:gemini-2.5-flash "What is Ruby?"'
          opts.separator '  ace-llm-query gflash "Quick question" # using alias'
          opts.separator '  ace-llm-query google --prompt "What is Ruby?" # using --prompt flag'
          opts.separator '  ace-llm-query google "What is Ruby?" --model gemini-2.0-flash-lite'
          opts.separator '  ace-llm-query gflash "test" --model gemini-pro # override alias model'
          opts.separator '  ace-llm-query openai --prompt prompt.txt --output response.md'
          opts.separator '  ace-llm-query google --prompt "Query with $vars" # avoid escaping issues'
          opts.separator ""
          opts.separator "Providers: #{available_provider_names.join(', ')}"
          opts.separator ""
          opts.separator "Use --list-providers to see all providers and their status"
        end
      end

      def show_provider_help
        puts "Available aliases for '#{@provider_model}':"
        puts ""

        # Show aliases from resolver
        resolver = Ace::LLM::Molecules::LlmAliasResolver.new
        aliases = resolver.available_aliases

        if aliases[:global] && !aliases[:global].empty?
          puts "Global aliases:"
          aliases[:global].each do |alias_name, target|
            puts "  #{alias_name} → #{target}"
          end
        end

        puts ""
        puts "Use: ace-llm-query #{@provider_model} \"your prompt here\""
      end

      def execute_query
        # Parse provider and model
        parser = Ace::LLM::Molecules::ProviderModelParser.new
        parse_result = parser.parse(@provider_model)

        unless parse_result.valid?
          error_output(parse_result.error)
          exit(1)
        end

        # Resolve final model: --model flag > positional :MODEL > provider default
        final_model = @options[:model] || parse_result.model

        # Validate that we have a model from some source
        if final_model.nil? || final_model.empty?
          error_output("No model specified and no default available for #{parse_result.provider}")
          error_output("Use --model MODEL or PROVIDER:MODEL syntax")
          exit(1)
        end

        # Load prompt content
        file_handler = Ace::LLM::Molecules::FileIoHandler.new
        prompt_text = file_handler.read_content(@prompt)

        # Build messages
        messages = build_messages(prompt_text)

        # Create client and generate response
        client = create_client(parse_result.provider, final_model)
        response = client.generate(messages, **generation_options)

        # Format and output response
        output_response(response)
      end

      def build_messages(prompt_text)
        messages = []

        # Add system message if provided
        if @options[:system]
          file_handler = Ace::LLM::Molecules::FileIoHandler.new
          system_text = file_handler.read_content(@options[:system])
          messages << { role: "system", content: system_text }
        end

        # Add user message
        messages << { role: "user", content: prompt_text }
        messages
      end

      def create_client(provider, model)
        # Use registry to get client
        @registry.get_client(
          provider,
          model: model,
          timeout: @options[:timeout]
        )
      rescue Ace::LLM::ProviderError => e
        error_output(e.message)
        error_output("Available providers: #{@registry.available_providers.join(', ')}")
        exit(1)
      rescue LoadError => e
        error_output("Provider '#{provider}' requires missing gem: #{e.message}")
        error_output("Please install the required gem and try again")
        exit(1)
      end

      def generation_options
        opts = {}
        opts[:temperature] = @options[:temperature] if @options[:temperature]
        opts[:max_tokens] = @options[:max_tokens] if @options[:max_tokens]
        opts
      end

      def output_response(response)
        # Get format handler
        handler = Ace::LLM::Molecules::FormatHandlers.get_handler(@options[:format])
        formatted_output = handler.format(response)

        if @options[:output]
          # Write to file
          file_handler = Ace::LLM::Molecules::FileIoHandler.new
          file_handler.write_content(
            formatted_output,
            @options[:output],
            format: @options[:format],
            force: @options[:force]
          )

          # Show summary
          puts handler.generate_summary(response, @options[:output])
        else
          # Output to stdout
          puts formatted_output
        end
      end

      def error_output(message)
        $stderr.puts "Error: #{message}"
      end

      def list_providers
        puts "Available LLM Providers:"
        puts ""

        providers = @registry.list_providers_with_status

        providers.each do |provider|
          status = provider[:available] ? "✓" : "✗"
          api_status = if provider[:api_key_required]
                        provider[:api_key_present] ? "(API key configured)" : "(API key required)"
                      else
                        "(No API key needed)"
                      end

          puts "#{status} #{provider[:name]} #{api_status}"

          if provider[:models] && !provider[:models].empty?
            puts "  Models: #{provider[:models].join(', ')}"
          end

          unless provider[:available]
            puts "  Gem required: #{provider[:gem]}"
          end

          puts ""
        end
      end

      def available_provider_names
        @registry.available_providers
      end
    end
  end
end

# Run the CLI
cli = Ace::LLM::QueryCLI.new
cli.run(ARGV)