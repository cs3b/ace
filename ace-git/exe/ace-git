#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/ace/git"
require_relative "../lib/ace/git/cli"

# Start dry-cli with exception-based exit code handling (per ADR-023)
begin
  Ace::Git::CLI.start(ARGV)
rescue Ace::Core::CLI::Error => e
  warn e.message
  exit(e.exit_code)
end
