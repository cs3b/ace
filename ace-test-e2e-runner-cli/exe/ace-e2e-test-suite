#!/usr/bin/env ruby
# frozen_string_literal: true

require "ace/e2e_runner"

if ARGV.empty? || ARGV.first.start_with?("-")
  ARGV.unshift("suite")
elsif ARGV.first == "suite"
  # no-op
else
  ARGV.unshift("suite")
end

begin
  Ace::E2eRunner::CLI.start(ARGV)
rescue Ace::Core::CLI::Error => e
  warn e.message
  exit(e.exit_code)
end
