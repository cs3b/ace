# LM Studio Configuration
# =======================
# LM Studio runs locally and typically doesn't require an API key
# If your setup requires authentication, set this:
# LM_STUDIO_API_KEY=your_lm_studio_api_key_here

# Development Configuration
# =========================

# VCR Configuration
# Set to 'true' when recording new cassettes with real API calls
# VCR_RECORD=false

# Test Environment
# Set to 'test' when running tests
# NODE_ENV=test
