#!/bin/sh
# Wrapper for project linting.
# This script runs markdownlint for Markdown files and a custom Ruby script for checking links.

set -e
cd "$(dirname "$0")"/.. # Ensure execution from project root

echo "INFO: Running 'bin/lint' from project root: $(pwd)"

LINT_SUCCESS=true

# Run markdownlint for all Markdown files, ignoring node_modules
# Pass any arguments received by this script to markdownlint
echo "INFO: Running markdownlint..."
if npx markdownlint-cli '**/*.md' --config .markdownlint.json --ignore node_modules --ignore docs-project/done --ignore docs-project/sessions --fix "$@"; then
  echo "INFO: markdownlint passed."
else
  echo "ERROR: markdownlint found issues."
  LINT_SUCCESS=false
fi

# Run the custom Markdown link linter script
LINK_CHECKER_SCRIPT="docs-dev/tools/lint-md-links.rb"
echo "INFO: Running link checker script: $LINK_CHECKER_SCRIPT..."
if [ -f "$LINK_CHECKER_SCRIPT" ]; then
  # Assuming the script takes no arguments or handles them internally
  if ruby "$LINK_CHECKER_SCRIPT" docs-dev/**/*; then
    echo "INFO: Link checker ($LINK_CHECKER_SCRIPT) passed."
  else
    echo "ERROR: Link checker ($LINK_CHECKER_SCRIPT) found issues."
    LINT_SUCCESS=false
  fi
else
  echo "WARNING: Link checker script not found at $LINK_CHECKER_SCRIPT. Skipping."
  # Decide if this should be a failure. For now, it's a warning.
  # LINT_SUCCESS=false
fi

# Run the custom task metadata linter script
TASK_METADATA_LINTER_SCRIPT="docs-dev/tools/lint-task-metadata"
echo "INFO: Running task metadata linter script: $TASK_METADATA_LINTER_SCRIPT..."
if [ -f "$TASK_METADATA_LINTER_SCRIPT" ]; then
  if ruby "$TASK_METADATA_LINTER_SCRIPT"; then
    echo "INFO: Task metadata linter ($TASK_METADATA_LINTER_SCRIPT) passed."
  else
    echo "ERROR: Task metadata linter ($TASK_METADATA_LINTER_SCRIPT) found issues."
    LINT_SUCCESS=false
  fi
else
  echo "WARNING: Task metadata linter script not found at $TASK_METADATA_LINTER_SCRIPT. Skipping."
  # Consider if this should be a failure. For now, it's a warning.
  # LINT_SUCCESS=false
fi

if [ "$LINT_SUCCESS" = true ]; then
  echo "INFO: All linting checks passed."
  exit 0
else
  echo "ERROR: One or more linting checks failed."
  exit 1
fi
