#!/bin/sh
# Lint script for Coding Agent Tools gem
# Runs StandardRB linter with project configuration

set -e
cd "$(dirname "$0")"/.. # Ensure execution from project root

echo "INFO: Running StandardRB linter from project root: $(pwd)"
echo "INFO: Configuration loaded from .standard.yml"

# Run StandardRB with project configuration
bundle exec standardrb "$@"

# Check for any linting issues
if [ $? -eq 0 ]; then
  echo "SUCCESS: No linting issues found"
else
  echo "ERROR: Linting issues detected"
  echo "Run 'bundle exec standardrb --fix' to auto-fix issues where possible"
  exit 1
fi

echo "INFO: Linting completed successfully"
