#!/bin/bash
# Lint script for Coding Agent Tools gem
# Runs code-lint ruby and Gitleaks secrets scanner with project configuration

set -e

# If any arguments are passed, run ONLY those with code-lint ruby (no autofix)
if [[ $# -gt 0 ]]; then
  echo "🔧 Running custom code-lint ruby command:"
  echo "    code-lint ruby $@"
  exec code-lint ruby "$@"
fi

# No args — run the full cascade
echo "INFO: Running linters from dev-tools directory: $(pwd)"

# Run code-lint ruby for lib/ directory with autofix
echo "INFO: Running code-lint ruby for lib/**/*.rb with autofix..."
code-lint ruby --autofix lib/**/*.rb

# Run code-lint ruby for spec/ directory with autofix
echo "INFO: Running code-lint ruby for spec/**/*.rb with autofix..."
code-lint ruby --autofix spec/**/*.rb

# # Run security scanning using the local script
# echo "INFO: Running security scanning..."
# ./bin/lint-security

echo "INFO: All linting checks completed successfully"
