#!/bin/sh
# Lint script for Coding Agent Tools gem
# Runs StandardRB linter and Gitleaks secrets scanner with project configuration

set -e
cd "$(dirname "$0")"/.. # Ensure execution from project root

echo "INFO: Running linters from project root: $(pwd)"
echo "INFO: Configuration loaded from .standard.yml"

# Run StandardRB with project configuration
echo "INFO: Running StandardRB..."
bundle exec standardrb "$@"

# Check for StandardRB linting issues
standardrb_exit_code=$?
if [ $standardrb_exit_code -ne 0 ]; then
  echo "ERROR: StandardRB linting issues detected"
  echo "Run 'bundle exec standardrb --fix' to auto-fix issues where possible"
  exit 1
fi

echo "SUCCESS: StandardRB - No linting issues found"

# Run security scanning using the standalone script
echo "INFO: Running security scanning..."
"$(dirname "$0")/lint-security"

# Check for security scanning issues
security_exit_code=$?
if [ $security_exit_code -ne 0 ]; then
  echo "ERROR: Security issues detected"
  exit 1
fi

echo "INFO: All linting checks completed successfully"
