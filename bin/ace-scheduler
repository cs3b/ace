#!/usr/bin/env ruby
# frozen_string_literal: true

# Wrapper script to run ace-scheduler with proper bundler context
require "pathname"

ace_meta_root = Pathname.new(__FILE__).dirname.parent.realpath
ENV["BUNDLE_GEMFILE"] = ace_meta_root.join("Gemfile").to_s

require "bundler/setup"

load ace_meta_root.join("ace-scheduler/exe/ace-scheduler").to_s
