#!/usr/bin/env fish

set intention ""

set i 1
while test $i -le (count $argv)
    set arg $argv[$i]
    switch $arg
        case '-i' '--intention'
            set i (math $i + 1)
            set intention $argv[$i]
        case '*'
            # Ignore other arguments for now
    end
    set i (math $i + 1)
end

echo "Commit changes in submodule: docs-dev..."
pushd docs-dev
if test -n "$intention"
    gcama -i "$intention"
else
    gcama
end
popd

echo "Commit changes in submodule: docs-project..."
pushd docs-project
if test -n "$intention"
    gcama -i "$intention"
else
    gcama
end
popd

echo "Commit changes in main repository..."
if test -n "$intention"
    gcama -i "$intention"
else
    gcama
end

echo "All repositories committed successfully."

echo "\nRecent changes across all repos (last 1 day by default):"
set last_arg ""
for i in (seq (count $argv))
    if test $argv[$i] = "--last" -o $argv[$i] = "-last"
        set last_arg "$argv[$i] $argv[(math $i + 1)]"
    end
end

# Show recent git logs using the extracted tool
set script_path (dirname (status --current-filename))/../docs-dev/tools/recent-git-log
if test -n "$last_arg"
    $script_path --include-docs-dev --include-docs-project $last_arg
else
    $script_path --include-docs-dev --include-docs-project
end