#!/usr/bin/env fish

set intention ""

set i 1
while test $i -le (count $argv)
    set arg $argv[$i]
    switch $arg
        case '-i' '--intention'
            set i (math $i + 1)
            set intention $argv[$i]
        case '*'
            # Ignore other arguments for now
    end
    set i (math $i + 1)
end

echo "Commit changes in main repository..."
if test -n "$intention"
    gcama -i "$intention"
else
    gcama
end

echo "All repositories committed successfully."
