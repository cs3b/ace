#!/usr/bin/env ruby
# frozen_string_literal: true

#
# cr-all
#
# Run code-review prompts through one or many LLM providers.
#
# Usage:
#   cr-all PROMPT_FILE [OUTPUT_DIR] [PROVIDERS]
#
#   PROMPT_FILE  – Path to a prompt generated by `bin/cr`
#   OUTPUT_DIR   – Directory where review files will be written.
#                  Defaults to the directory of PROMPT_FILE.
#   PROVIDERS    – Comma-separated list of provider:model pairs.
#                  Defaults to "gemini:gemini-2.5-flash"
#
# Example:
#   bin/cr-all tmp/cr_prompt.md reviews \
#     "gemini:gemini-2.5-flash,openai:gpt-4o-mini"
#
# For every provider:model pair the script invokes
#   exe/llm-<provider>-query
# with:
#   * the given prompt file
#   * --model     <model>
#   * --system    <system prompt below>
#   * --format    markdown
#   * --output    OUTPUT_DIR/code-review-<provider>-<model>.md
#
# ---------------------------------------------------------------------------

require "fileutils"
require "optparse"
require "tempfile"

# ---------------------------------------------------------------------------
SYSTEM_PROMPT = <<~PROMPT
"  You are an experienced senior software engineer and code reviewer with deep knowledge of software architecture, clean code principles, testing strategies, and modern development practices. You are familiar with the entire codebase and its design decisions.

  When reviewing code:
  • Understand the intent and context of the changes.
  • Provide concise, actionable, and high-value feedback.
  • Prioritize readability, maintainability, performance, security, and consistency with the existing codebase.
  • Highlight both strengths and issues in the code.
  • Suggest specific improvements where applicable (e.g., better naming, simplifying logic, improving structure, avoiding anti-patterns).
  • Reference relevant conventions, standards, or patterns used in this codebase if they apply.
  • Avoid generic or redundant comments. Do not restate what the code obviously does.
  • Use a professional, collaborative tone—as if mentoring a peer. "
PROMPT
# ---------------------------------------------------------------------------

# --- CLI parsing -----------------------------------------------------------
if ARGV.empty?
  warn "Usage: cr-all PROMPT_FILE [OUTPUT_DIR] [PROVIDERS]"
  exit 1
end

prompt_file = File.expand_path(ARGV[0])
unless File.file?(prompt_file)
  warn "Prompt file not found: #{prompt_file}"
  exit 1
end

# Detect whether second argument is an output directory or a providers list.
output_dir, providers_arg =
  case ARGV[1]
  when nil
    [File.dirname(prompt_file), nil]
  when ->(arg) { arg&.include?(":") || arg&.include?(",") }
    [File.dirname(prompt_file), ARGV[1]]
  else
    [ARGV[1], ARGV[2]]
  end

output_dir = File.expand_path(output_dir)
providers_arg ||= "gemini:gemini-2.5-flash"

providers = providers_arg.split(",").map(&:strip).reject(&:empty?)

# ---------------------------------------------------------------------------
# Prepare shared system-prompt file.
system_prompt_file = Tempfile.new(%w[cr-system-prompt .md])
system_prompt_file.write(SYSTEM_PROMPT)
system_prompt_file.flush
system_prompt_path = system_prompt_file.path

# Ensure output directory exists.
FileUtils.mkdir_p(output_dir)

# Locate repository root (two levels up from this script: <root>/bin/cr-all).
SCRIPT_DIR = File.expand_path(__dir__)
PROJECT_ROOT = File.expand_path("..", SCRIPT_DIR)
EXE_DIR = File.join(PROJECT_ROOT, "exe")

# ---------------------------------------------------------------------------
exit_status = 0

providers.each do |pair|
  provider, model = pair.split(":", 2)
  if provider.nil? || model.nil? || provider.empty? || model.empty?
    warn "Skipping invalid provider specification '#{pair}'. Expected 'provider:model'."
    exit_status = 1
    next
  end

  exe_path = File.join(EXE_DIR, "llm-#{provider}-query")
  unless File.executable?(exe_path)
    warn "Executable not found for provider '#{provider}': #{exe_path}"
    exit_status = 1
    next
  end

  output_file = File.join(output_dir, "code-review-#{provider}-#{model}.md")

  cmd = [
    exe_path,
    prompt_file,
    "--output", output_file,
    "--format", "markdown",
    "--model", model,
    "--timeout", (60 * 15).to_s,
    "--system", system_prompt_path
  ]

  puts cmd

  puts "⏳  Running review with #{provider}:#{model} → #{output_file}"
  success = system(*cmd)
  if success
    puts "✅  Review written to #{output_file}"
  else
    warn "❌  Review generation failed for #{provider}:#{model}"
    exit_status = 1
  end
end

# Cleanup
system_prompt_file.close!
exit exit_status
