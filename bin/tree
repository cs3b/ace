#!/bin/bash
# bin/tree - Thin wrapper around the utils/tree script
#
# This wrapper provides a convenient way to run the project's
# customized tree command with default settings. For more options,
# see dev-tools/exe-old/show-directory-tree --help

# Get the project root directory
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
UTILS_TREE="${ROOT_DIR}/dev-tools/exe-old/show-directory-tree"

# Check if the utils/tree script exists and is executable
if [ ! -x "$UTILS_TREE" ]; then
    echo "Error: Could not find executable tree script at $UTILS_TREE"
    echo "Please ensure the script exists and has execute permissions."
    exit 1
fi

# Forward all arguments to the utils/tree script
"$UTILS_TREE" "$@"