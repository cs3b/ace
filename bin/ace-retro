#!/usr/bin/env ruby
# frozen_string_literal: true

# Wrapper script to run ace-retro with proper bundler context
require "pathname"

# Find the ace root directory
ace_meta_root = Pathname.new(__FILE__).dirname.parent.realpath

# Set the Gemfile location
ENV["BUNDLE_GEMFILE"] = ace_meta_root.join("Gemfile").to_s

# Load bundler
require "bundler/setup"

# Now require and run the actual ace-retro executable
load ace_meta_root.join("ace-retro/exe/ace-retro").to_s
