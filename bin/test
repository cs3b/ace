#!/bin/bash

# If any arguments are passed, run ONLY those
if [[ $# -gt 0 ]]; then
  echo "🔧 Running custom RSpec command:"
  echo "    bundle exec rspec $@"
  exec bundle exec rspec "$@"
fi

# No args — run the full cascade
echo "🧪 Running UNIT tests (excluding integration and slow)..."
bundle exec rspec --exclude-pattern "spec/integration/**/*_spec.rb" --tag ~slow --fail-fast

echo "✅ Unit tests passed. Now running INTEGRATION tests..." --fail-fast
bundle exec rspec spec/integration

echo "✅ Integration tests passed. Now running SLOW tests..." --fail-fast
bundle exec rspec --tag slow

echo "🎉 All tests passed!"
