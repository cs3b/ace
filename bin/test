#!/bin/sh
# Test script for Coding Agent Tools gem
# Runs RSpec test suite with coverage reporting

set -e
cd "$(dirname "$0")"/.. # Ensure execution from project root

echo "INFO: Running RSpec test suite with coverage from project root: $(pwd)"
echo "INFO: Coverage reports will be generated in coverage/ directory"

# Run RSpec with coverage reporting
bundle exec rspec --format progress "$@"

# Check if coverage report was generated
if [ -f "coverage/index.html" ]; then
  echo "SUCCESS: Coverage report generated at coverage/index.html"
else
  echo "WARNING: Coverage report not found"
fi

echo "INFO: Test run completed"
