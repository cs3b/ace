#!/bin/bash

# Enhanced Test Runner for Coding Agent Tools
# Supports parallel execution by default with comprehensive fallback options

set -euo pipefail

# Configuration
DEFAULT_PARALLEL_WORKERS=4
COVERAGE_DIR="coverage"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
log_info() {
    echo -e "${BLUE}🔧${NC} $1"
}

log_success() {
    echo -e "${GREEN}✅${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}⚠️${NC} $1"
}

log_error() {
    echo -e "${RED}❌${NC} $1"
}

# Check if parallel_tests is available
check_parallel_tests() {
    if command -v parallel_rspec >/dev/null 2>&1; then
        return 0
    else
        log_warning "parallel_tests gem not found. Install with: bundle add parallel_tests --group development,test"
        return 1
    fi
}

# Clean coverage reports
clean_coverage() {
    if [[ -d "$COVERAGE_DIR" ]]; then
        rm -rf "$COVERAGE_DIR"
        log_info "Cleaned previous coverage reports"
    fi
}

# Merge coverage reports (for parallel execution)
merge_coverage() {
    if [[ -d "$COVERAGE_DIR" ]] && ls "$COVERAGE_DIR"/.resultset*.json >/dev/null 2>&1; then
        log_info "Merging coverage reports..."
        ruby -e "
        require 'bundler/setup'
        require 'simplecov'
        
        coverage_files = Dir['$COVERAGE_DIR/.resultset*.json']
        puts \"Merging #{coverage_files.size} coverage file(s)...\"
        
        SimpleCov.collate coverage_files do
            formatter SimpleCov::Formatter::MultiFormatter.new([
                SimpleCov::Formatter::HTMLFormatter
            ])
            
            add_filter '/spec/'
            add_filter '/vendor/'
            add_filter '/.bundle/'
            add_group 'Library', 'lib'
            track_files 'lib/**/*.rb'
        end
        
        puts '✓ Coverage reports merged successfully'
        " 2>/dev/null
        log_success "Coverage report available in $COVERAGE_DIR/index.html"
    fi
}

# Run tests with parallel execution
run_parallel() {
    local pattern="$1"
    local rspec_options="$2"
    local workers="${3:-$DEFAULT_PARALLEL_WORKERS}"
    
    log_info "Running tests in parallel ($workers workers)"
    
    if check_parallel_tests; then
        # Build the command carefully
        local -a cmd_args=("bundle" "exec" "parallel_rspec")
        
        # Add pattern
        if [[ "$pattern" != "spec/" ]]; then
            cmd_args+=("$pattern")
        else
            cmd_args+=("spec/")
        fi
        
        # Add workers
        cmd_args+=("-n" "$workers")
        
        # Handle common RSpec options that have parallel_rspec equivalents
        if [[ "$rspec_options" == *"--exclude-pattern"* ]]; then
            # Extract exclude pattern and convert to parallel_rspec format
            if [[ "$rspec_options" =~ --exclude-pattern[[:space:]]+[\'\"]*([^[:space:]\'\"]+) ]]; then
                local exclude_pattern="${BASH_REMATCH[1]}"
                cmd_args+=("--exclude-pattern" "$exclude_pattern")
                # Remove the exclude-pattern from rspec_options for the rest
                rspec_options="${rspec_options/--exclude-pattern *${exclude_pattern}/}"
            fi
        fi
        
        # Add remaining RSpec options after -- separator
        if [[ -n "$rspec_options" && "$rspec_options" != " " ]]; then
            cmd_args+=("--")
            # Split rspec_options string into array and add each part
            IFS=' ' read -ra option_parts <<< "$rspec_options"
            cmd_args+=("${option_parts[@]}")
        fi
        
        log_info "Executing: ${cmd_args[*]}"
        "${cmd_args[@]}"
    else
        log_warning "Falling back to sequential execution"
        run_sequential "$pattern" "$rspec_options"
    fi
}

# Run tests sequentially (fallback)
run_sequential() {
    local pattern="$1"
    local tags="$2"
    
    log_info "Running tests sequentially"
    
    local cmd="bundle exec rspec"
    
    if [[ "$pattern" != "spec/" ]]; then
        cmd="$cmd $pattern"
    fi
    
    if [[ -n "$tags" ]]; then
        cmd="$cmd $tags"
    fi
    
    log_info "Executing: $cmd"
    eval "$cmd"
}

# Main test suites
run_unit_tests() {
    local workers="${1:-$DEFAULT_PARALLEL_WORKERS}"
    log_info "Running UNIT tests (excluding integration and slow tests)..."
    
    clean_coverage
    
    # Use parallel_rspec's exclude-pattern option directly
    if check_parallel_tests; then
        log_info "Running tests in parallel ($workers workers)"
        log_info "Executing: bundle exec parallel_rspec spec/ -n $workers --exclude-pattern 'spec/integration/.*' -- --tag ~slow --fail-fast=3"
        bundle exec parallel_rspec spec/ -n "$workers" --exclude-pattern 'spec/integration/.*' -- --tag ~slow --fail-fast=3
    else
        log_warning "Falling back to sequential execution"
        bundle exec rspec spec/ --exclude-pattern 'spec/integration/**/*_spec.rb' --tag ~slow --fail-fast=3
    fi
    
    merge_coverage
}

run_integration_tests() {
    local workers="${1:-2}"  # Integration tests typically run with fewer workers
    log_info "Running INTEGRATION tests..."
    
    run_parallel "spec/integration/" "--fail-fast=1" "$workers"
}

run_slow_tests() {
    local workers="${1:-1}"  # Slow tests should run with minimal parallelization
    log_info "Running SLOW tests..."
    
    run_parallel "spec/" "--tag slow --fail-fast=1" "$workers"
}

run_cli_tests() {
    local workers="${1:-1}"  # CLI tests need isolation - single worker or very limited
    log_info "Running CLI tests with isolation..."
    
    # CLI tests require special handling due to heavy library loading
    run_parallel "spec/coding_agent_tools/cli/" "--fail-fast=1" "$workers"
}

run_all_tests() {
    local workers="${1:-$DEFAULT_PARALLEL_WORKERS}"
    log_info "Running ALL tests (unit, integration, and slow)..."
    
    clean_coverage
    
    # Run all test types in phases
    log_info "Phase 1: Unit tests (excluding CLI for now)"
    run_parallel "spec/" "--exclude-pattern 'spec/integration/**/*_spec.rb' --exclude-pattern 'spec/coding_agent_tools/cli/**/*_spec.rb' --tag ~slow" "$workers"
    
    log_info "Phase 2: CLI tests with isolation"
    run_cli_tests "1"  # Force single worker for CLI tests
    
    log_info "Phase 3: Integration tests" 
    run_parallel "spec/integration/" "--fail-fast=1" "2"  # Fewer workers for integration
    
    log_info "Phase 4: Slow tests"
    run_parallel "spec/" "--tag slow --fail-fast=1" "1"  # Single worker for slow tests
    
    merge_coverage
    log_success "All test phases completed!"
}

# Show usage information
show_usage() {
    cat << EOF
Usage: bin/test [COMMAND|OPTIONS] [-- RSPEC_OPTIONS]

Commands:
  :all              Run all tests (unit, integration, slow) in phases
  :unit             Run only unit tests (default)
  :integration      Run only integration tests  
  :slow             Run only slow tests
  :cli              Run only CLI tests with isolation
  :sequential       Force sequential execution (no parallel)

Options:
  -w, --workers N   Number of parallel workers (default: $DEFAULT_PARALLEL_WORKERS)
  -h, --help        Show this help message

Examples:
  bin/test                           # Run unit tests in parallel (4 workers)
  bin/test :all                      # Run all test suites in phases
  bin/test :integration              # Run only integration tests
  bin/test :cli                      # Run CLI tests with isolation
  bin/test -w 2                      # Run unit tests with 2 workers
  bin/test :sequential               # Force sequential execution
  bin/test spec/specific_test_spec.rb # Run specific test file in parallel
  bin/test -- --tag focus            # Pass RSpec options after --

Backward Compatibility:
  - Arguments matching file/directory paths run ONLY those tests
  - RSpec options can be passed after -- separator
  - Default behavior (no args) runs unit tests in parallel

Note: If parallel_tests gem is not available, will fallback to sequential execution.
Install with: bundle add parallel_tests --group development,test
EOF
}

# Parse command line arguments
WORKERS="$DEFAULT_PARALLEL_WORKERS"
COMMAND=""
RSPEC_ARGS=""
PARSE_RSPEC_ARGS=false

while [[ $# -gt 0 ]]; do
    if [[ "$PARSE_RSPEC_ARGS" == true ]]; then
        RSPEC_ARGS="$RSPEC_ARGS $1"
        shift
        continue
    fi
    
    case $1 in
        :all)
            COMMAND="all"
            shift
            ;;
        :unit)
            COMMAND="unit"
            shift
            ;;
        :integration)
            COMMAND="integration"
            shift
            ;;
        :slow)
            COMMAND="slow"
            shift
            ;;
        :cli)
            COMMAND="cli"
            shift
            ;;
        :sequential)
            COMMAND="sequential"
            shift
            ;;
        -w|--workers)
            WORKERS="$2"
            if ! [[ "$WORKERS" =~ ^[0-9]+$ ]] || [[ "$WORKERS" -lt 1 ]]; then
                log_error "Workers must be a positive integer"
                exit 1
            fi
            shift 2
            ;;
        -h|--help)
            show_usage
            exit 0
            ;;
        --)
            PARSE_RSPEC_ARGS=true
            shift
            ;;
        *)
            # Backward compatibility: If it looks like a file/directory path or RSpec option
            if [[ "$1" =~ ^spec/ ]] || [[ "$1" =~ ^- ]]; then
                log_info "Running custom RSpec command with parallel execution:"
                if check_parallel_tests; then
                    # Use parallel execution for custom file/directory targeting
                    log_info "    bundle exec parallel_rspec $* -n $WORKERS"
                    exec bundle exec parallel_rspec "$@" -n "$WORKERS"
                else
                    log_info "    bundle exec rspec $*"
                    exec bundle exec rspec "$@"
                fi
            else
                log_error "Unknown option: $1"
                show_usage
                exit 1
            fi
            ;;
    esac
done

# Execute based on command
case "${COMMAND:-unit}" in
    all)
        run_all_tests "$WORKERS"
        ;;
    unit)
        run_unit_tests "$WORKERS"
        ;;
    integration)
        run_integration_tests "$WORKERS"
        ;;
    slow)
        run_slow_tests "$WORKERS"
        ;;
    cli)
        run_cli_tests "$WORKERS"
        ;;
    sequential)
        log_info "Running unit tests sequentially (no parallel)"
        run_sequential "spec/" "--exclude-pattern 'spec/integration/**/*_spec.rb' --tag ~slow --fail-fast=3"
        ;;
    *)
        log_error "Unknown command: $COMMAND"
        show_usage
        exit 1
        ;;
esac

log_success "Test execution completed!"