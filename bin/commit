#!/usr/bin/env fish

set intention ""

for arg in $argv
    switch $arg
        case '-i' '--intention'
            set intention (next $argv)
        case '*'
            # Ignore other arguments
    end
end

echo "Commit changes in submodule: docs-dev..."
pushd docs-dev
if test -n "$intention"
    gcama "$intention"
else
    gcama
end
popd

echo "Commit changes in submodule: docs-project..."
pushd docs-project
if test -n "$intention"
    gcama "$intention"
else
    gcama
end
popd

echo "Commit changes in main repository..."
if test -n "$intention"
    gcama "$intention"
else
    gcama
end

echo "All repositories committed successfully."