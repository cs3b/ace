#!/usr/bin/env ruby

require 'fileutils'
require 'set'
require 'json'

# Analyze dependencies between documentation files
class DocumentDependencyAnalyzer
  def initialize
    @dependencies = Hash.new { |h, k| h[k] = { refs_to: Set.new, refs_from: Set.new } }
    @file_types = {
      workflows: 'dev-handbook/workflow-instructions/**/*.wf.md',
      guides: 'dev-handbook/guides/**/*.g.md',
      tasks: 'dev-taskflow/**/tasks/*.md',
      docs: 'docs/*.md',
      taskflow_docs: 'dev-taskflow/*.md'
    }
  end

  def analyze
    # Collect all files
    all_files = collect_all_files
    
    # Analyze each file for references
    all_files.each do |file|
      analyze_file(file, all_files)
    end
    
    # Output results
    output_results
  end

  private

  def collect_all_files
    files = Set.new
    @file_types.each do |_type, pattern|
      Dir.glob(pattern).each { |f| files << f if File.file?(f) }
    end
    files
  end

  def analyze_file(file, all_files)
    content = File.read(file)
    
    # Find markdown links
    content.scan(/\[([^\]]+)\]\(([^)]+)\)/).each do |_text, link|
      next if link.start_with?('http://', 'https://', '#')
      
      # Resolve relative links
      target = resolve_link(file, link)
      
      # Check if target exists in our file set
      if all_files.include?(target)
        @dependencies[file][:refs_to] << target
        @dependencies[target][:refs_from] << file
      end
    end
    
    # Find file references in code blocks and context loading
    content.scan(/(?:Load|load|Check|check|Read|read|See|see).*?[:\s]+`([^`]+\.(?:md|wf\.md|g\.md))`/i).each do |ref|
      target = ref[0]
      # Try to resolve as absolute path from root
      if File.exist?(target)
        @dependencies[file][:refs_to] << target
        @dependencies[target][:refs_from] << file
      end
    end
  end

  def resolve_link(from_file, link)
    # Remove anchors
    link = link.split('#').first
    
    # Handle absolute paths from root
    return link if link.start_with?('/')
    
    # Handle relative paths
    from_dir = File.dirname(from_file)
    File.expand_path(link, from_dir).sub("#{Dir.pwd}/", '')
  end

  def output_results
    puts "# Document Dependency Analysis"
    puts "Generated: #{Time.now}"
    puts
    
    # Summary statistics
    puts "## Summary"
    puts "- Total files analyzed: #{@dependencies.count}"
    puts "- Files with outgoing references: #{@dependencies.count { |_, deps| deps[:refs_to].any? }}"
    puts "- Files with incoming references: #{@dependencies.count { |_, deps| deps[:refs_from].any? }}"
    puts
    
    # Most referenced files
    puts "## Most Referenced Files (Top 10)"
    most_referenced = @dependencies
      .select { |_, deps| deps[:refs_from].any? }
      .sort_by { |_, deps| -deps[:refs_from].size }
      .first(10)
    
    most_referenced.each do |file, deps|
      puts "- **#{file}** - Referenced by #{deps[:refs_from].size} files"
    end
    puts
    
    # Orphaned files (no incoming references)
    orphaned = @dependencies.select { |_, deps| deps[:refs_from].empty? && deps[:refs_to].empty? }
    if orphaned.any?
      puts "## Orphaned Files (No References)"
      orphaned.keys.sort.each { |f| puts "- #{f}" }
      puts
    end
    
    # Circular dependencies
    circular = find_circular_dependencies
    if circular.any?
      puts "## Circular Dependencies"
      circular.each do |cycle|
        puts "- #{cycle.join(' → ')} → #{cycle.first}"
      end
      puts
    end
    
    # Output dependency graph in DOT format
    output_dot_graph
    
    # Output JSON for further processing
    output_json
  end

  def find_circular_dependencies
    circular = Set.new
    
    @dependencies.each_key do |file|
      visited = Set.new
      path = []
      
      if has_cycle?(file, visited, path, Set.new)
        # Extract the cycle from the path
        cycle_start = path.rindex(path.last)
        cycle = path[cycle_start..-1]
        circular << cycle.sort
      end
    end
    
    circular.to_a
  end

  def has_cycle?(node, visited, path, rec_stack)
    visited << node
    rec_stack << node
    path << node
    
    @dependencies[node][:refs_to].each do |neighbor|
      if !visited.include?(neighbor)
        return true if has_cycle?(neighbor, visited, path, rec_stack)
      elsif rec_stack.include?(neighbor)
        path << neighbor
        return true
      end
    end
    
    path.pop
    rec_stack.delete(node)
    false
  end

  def output_dot_graph
    File.open('doc-dependencies.dot', 'w') do |f|
      f.puts "digraph DocumentDependencies {"
      f.puts "  rankdir=LR;"
      f.puts "  node [shape=box];"
      
      # Color nodes by type
      @dependencies.each_key do |file|
        color = case file
                when /\.wf\.md$/ then 'lightblue'
                when /\.g\.md$/ then 'lightgreen'
                when /tasks.*\.md$/ then 'lightyellow'
                else 'lightgray'
                end
        f.puts "  \"#{file}\" [fillcolor=#{color}, style=filled];"
      end
      
      # Add edges
      @dependencies.each do |from, deps|
        deps[:refs_to].each do |to|
          f.puts "  \"#{from}\" -> \"#{to}\";"
        end
      end
      
      f.puts "}"
    end
    
    puts "## Visualization"
    puts "Dependency graph saved to: doc-dependencies.dot"
    puts "To generate an image: dot -Tpng doc-dependencies.dot -o doc-dependencies.png"
    puts
  end

  def output_json
    data = {}
    @dependencies.each do |file, deps|
      data[file] = {
        references: deps[:refs_to].to_a,
        referenced_by: deps[:refs_from].to_a
      }
    end
    
    File.write('doc-dependencies.json', JSON.pretty_generate(data))
    puts "Detailed dependency data saved to: doc-dependencies.json"
  end
end

# Run the analyzer
DocumentDependencyAnalyzer.new.analyze