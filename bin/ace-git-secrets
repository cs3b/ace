#!/usr/bin/env ruby
# frozen_string_literal: true

# Wrapper script to run ace-git-secrets with proper bundler context
require "pathname"

# Find the ace root directory
ace_meta_root = Pathname.new(__FILE__).dirname.parent.realpath

# Set the Gemfile location
ENV["BUNDLE_GEMFILE"] = ace_meta_root.join("Gemfile").to_s

# Load bundler
require "bundler/setup"

# Now require and run the actual ace-git-secrets executable
load ace_meta_root.join("ace-git-secrets/exe/ace-git-secrets").to_s
