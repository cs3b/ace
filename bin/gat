#!/usr/bin/env ruby
# bin/gat: Thin wrapper for get-all-tasks utility

# This script assumes it is located in <project_root>/bin/
# The target script is in <project_root>/docs-dev/tools/
# File.expand_path calculates the absolute path.
# __dir__ gives the directory of the current script (bin/).
# '../docs-dev/tools/get-all-tasks' navigates from bin/ up to project_root and then down.

target_script = File.expand_path('../docs-dev/tools/get-all-tasks', __dir__)

if File.exist?(target_script)
  # Replace the current process with the Ruby interpreter running the target script
  # Pass all original arguments ($*) from this binstub to the target script
  exec(Gem.ruby, target_script, *ARGV)
else
  warn "Error: Target script not found at #{target_script}"
  warn "Ensure 'docs-dev/tools/get-all-tasks' exists."
  exit 1
end