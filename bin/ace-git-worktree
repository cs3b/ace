#!/usr/bin/env fish
# Wrapper script for ace-git-worktree with auto-navigation

# Find the ace-meta root directory
set ace_meta_root (dirname (dirname (realpath (status current-filename))))

# Set the Gemfile location
set -x BUNDLE_GEMFILE "$ace_meta_root/Gemfile"

# Run the actual command and capture output
set output (ruby -rbundler/setup "$ace_meta_root/ace-git-worktree/exe/ace-git-worktree" $argv 2>&1)
set exit_code $status

# Print the output
echo $output

# Extract worktree path and change directory if present
set worktree_path (echo $output | grep '^WORKTREE_PATH=' | cut -d= -f2)
if test -n "$worktree_path"; and test -d "$worktree_path"
    cd $worktree_path
    mise trust 2>/dev/null
end

exit $exit_code
