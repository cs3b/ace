# Coding Agent Tools Environment Configuration
# ==============================================
# This is a sample environment configuration file for coding-agent-tools.
# Copy this file to .coding-agent/.env in your project root or ~/.coding-agent/.env for global configuration.
#
# Priority order:
# 1. Project-specific: <project_root>/.coding-agent/.env (overrides global)
# 2. Global: ~/.coding-agent/.env (fallback)

# LLM Provider API Keys
# =====================
# These keys are required for using various LLM providers with the coding-agent-tools.

# Google Gemini API Key
# Get your API key from: https://makersuite.google.com/app/apikey
# Used by: llm-query --provider google, code-review, and other tools
GOOGLE_API_KEY=your_actual_gemini_api_key_here

# OpenAI API Key
# Get your API key from: https://platform.openai.com/api-keys
# Used by: llm-query --provider openai, various synthesis tools
OPENAI_API_KEY=your_actual_openai_api_key_here

# Anthropic Claude API Key
# Get your API key from: https://console.anthropic.com/
# Used by: llm-query --provider anthropic, Claude-specific integrations
ANTHROPIC_API_KEY=your_actual_anthropic_api_key_here

# Mistral AI API Key
# Get your API key from: https://console.mistral.ai/
# Used by: llm-query --provider mistral, lightweight model queries
MISTRAL_API_KEY=your_actual_mistral_api_key_here

# Together AI API Key
# Get your API key from: https://api.together.xyz/settings/api-keys
# Used by: llm-query --provider together, batch processing
TOGETHER_API_KEY=your_actual_together_api_key_here

# LM Studio Configuration (Optional)
# ===================================
# LM Studio runs locally and typically doesn't require an API key.
# Uncomment and set this only if your LM Studio setup requires authentication.
# Used by: llm-query --provider lm_studio, local model testing
# LM_STUDIO_API_KEY=your_lm_studio_api_key_if_needed

# Development Configuration
# =========================
# These settings control development and testing behavior.

# VCR Cassette Recording Mode
# Set to 'true' when recording new VCR cassettes with real API calls.
# Set to 'false' or comment out for normal development/testing with recorded cassettes.
# VCR_RECORD=false

# Test Environment
# Set to 'test' when running tests to enable test-specific behavior.
# NODE_ENV=test

# Debug and Verbose Output
# Set to 'true' to enable debug output from various tools
# DEBUG=false
# VERBOSE=false

# CI/Testing Environment Variables
# =================================
# These are typically set by CI systems but can be configured locally for testing.

# Continuous Integration flag
# Set automatically by most CI systems (GitHub Actions, CircleCI, etc.)
# CI=false

# Test-specific configurations
# Used by test suites to control behavior
# TEST=false
# VCR_CASSETTE_NAME=custom_cassette_name

# Project Configuration
# =====================
# Project-specific environment variables.

# Project root directory (usually auto-detected)
# PROJECT_ROOT=/path/to/your/project

# Bundle Gemfile location (for Ruby projects)
# BUNDLE_GEMFILE=/path/to/Gemfile

# Notes:
# ------
# 1. Never commit this file with real API keys to version control
# 2. Always use .gitignore to exclude .coding-agent/.env from git
# 3. For production deployments, use environment variables directly
# 4. Project-specific .env files override global settings
# 5. Some tools may require specific API keys to function