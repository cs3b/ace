# frozen_string_literal: true

source "https://rubygems.org"

# Specify your gem's dependencies in ace-test-runner.gemspec
gemspec

# Local dependencies for development
gem "ace-core", path: "../ace-core"
gem "ace-test-support", path: "../ace-test-support"

group :development, :test do
  gem "rake", "~> 13.0"
  gem "minitest", "~> 5.0"
  gem "minitest-reporters", "~> 1.6"
end

# NOTE: This Gemfile is only for standalone development with `bundle exec`.
# For monorepo development without `bundle exec`, this gem uses .bundle/config
# pointing to the parent Gemfile (like other ace-* gems).
# Having this local Gemfile prevents `rake test` from working without `bundle exec`.