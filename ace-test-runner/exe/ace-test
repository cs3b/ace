#!/usr/bin/env ruby
# frozen_string_literal: true

# Prevent Minitest from autorunning when ace-test exits
ENV["MT_NO_AUTORUN"] = "1"

require "optparse"
require "ace/test_runner"

options = {
  format: "progress",  # Default to per-test progress
  save_reports: true,
  verbose: false,
  fail_fast: false,
  fix_deprecations: false,
  color: true,
  per_file: false  # Default to grouped execution for performance
}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: ace-test [target] [options] [files...]"
  opts.separator ""
  opts.separator "Targets:"
  opts.separator "  atoms       Run atom tests only"
  opts.separator "  molecules   Run molecule tests only"
  opts.separator "  organisms   Run organism tests only"
  opts.separator "  models      Run model tests only"
  opts.separator "  unit        Run all unit tests (atoms + molecules + organisms + models)"
  opts.separator "  integration Run integration tests"
  opts.separator "  system      Run system tests"
  opts.separator "  all         Run all tests (default)"
  opts.separator "  quick       Run quick tests (atoms + molecules)"
  opts.separator "  clean-test-reports  Delete all test reports except the latest"
  opts.separator ""
  opts.separator "Options:"

  opts.on("-f", "--format FORMAT", %w[json progress progress-file],
          "Output format: progress (default), progress-file, json") do |format|
    options[:format] = format
  end

  opts.on("-d", "--report-dir DIR", "Report storage directory (default: test-reports/)") do |dir|
    options[:report_dir] = dir
  end

  opts.on("--no-save", "Skip saving detailed reports") do
    options[:save_reports] = false
  end

  opts.on("--fail-fast", "Stop execution on first failure") do
    options[:fail_fast] = true
  end

  opts.on("--fix-deprecations", "Auto-fix deprecated test patterns") do
    options[:fix_deprecations] = true
  end

  opts.on("--filter PATTERN", "Run only tests matching pattern") do |pattern|
    options[:filter] = pattern
  end

  opts.on("-g", "--group GROUP", "Run specific test group (unit, integration, system, all)") do |group|
    options[:group] = group
  end

  opts.on("-v", "--verbose", "Show detailed test execution") do
    options[:verbose] = true
  end

  opts.on("--[no-]color", "Enable/disable colored output (default: enabled)") do |color|
    options[:color] = color
  end

  opts.on("-c", "--config FILE", "Configuration file path (default: .ace/test-runner.yml)") do |config|
    options[:config_path] = config
  end

  opts.on("--timeout SECONDS", Integer, "Timeout for test execution in seconds") do |timeout|
    options[:timeout] = timeout
  end

  opts.on("--parallel", "Run tests in parallel (experimental)") do
    options[:parallel] = true
  end

  opts.on("--per-file", "Execute each test file separately (slower, for debugging)") do
    options[:per_file] = true
  end

  opts.separator ""
  opts.separator "Rake Integration:"

  opts.on("--set-default-rake-test", "Set ace-test as default rake test runner") do
    options[:set_default_rake] = true
  end

  opts.on("--unset-default-rake-test", "Remove ace-test as default rake test runner") do
    options[:unset_default_rake] = true
  end

  opts.on("--check-rake-test", "Check if ace-test is set as default rake test runner") do
    options[:check_rake_status] = true
  end

  opts.separator ""
  opts.separator "Report Management:"

  opts.on("--cleanup-reports", "Clean up old test reports (keeps last 10)") do
    options[:cleanup_reports] = true
  end

  opts.on("--cleanup-keep N", Integer, "Number of reports to keep when cleaning (default: 10)") do |n|
    options[:cleanup_keep] = n
  end

  opts.on("--cleanup-age DAYS", Integer, "Delete reports older than DAYS (default: 30)") do |days|
    options[:cleanup_age] = days
  end

  opts.on("-h", "--help", "Display this help") do
    puts opts
    exit 0
  end

  opts.on("--version", "Display version") do
    puts "ace-test-runner #{Ace::TestRunner::VERSION}"
    exit 0
  end

  opts.separator ""
  opts.separator "Examples:"
  opts.separator "  ace-test                         # Run all tests (default)"
  opts.separator "  ace-test atoms                   # Run only atom tests"
  opts.separator "  ace-test unit                    # Run all unit tests"
  opts.separator "  ace-test unit --format progress  # Run unit tests with progress display"
  opts.separator "  ace-test quick                   # Run quick tests (atoms + molecules)"
  opts.separator "  ace-test --format json           # JSON output for programmatic use"
  opts.separator "  ace-test test/foo_test.rb        # Run specific file"
  opts.separator "  ace-test test/foo_test.rb:42    # Run test at specific line"
  opts.separator "  ace-test --filter user           # Run only tests matching 'user'"
  opts.separator "  ace-test --fail-fast --verbose   # Stop on first failure with details"
  opts.separator "  ace-test clean-test-reports      # Delete all test reports except latest"
  opts.separator ""
  opts.separator "Rake Integration Examples:"
  opts.separator "  ace-test --set-default-rake-test   # Set ace-test as default for 'rake test'"
  opts.separator "  ace-test --check-rake-test         # Check current rake test configuration"
  opts.separator "  ace-test --unset-default-rake-test # Restore original rake test runner"
  opts.separator ""
end

begin
  parser.parse!(ARGV)
rescue OptionParser::InvalidArgument => e
  puts "Error: #{e.message}"
  puts
  puts parser
  exit 1
end

# Parse target argument (first non-option argument)
known_targets = %w[atoms molecules organisms models unit integration system all quick clean-test-reports]
target = nil
test_files = []
line_number = nil

ARGV.each do |arg|
  if arg =~ /^(.+):(\d+)$/
    # File with line number
    test_files << $1
    line_number = $2.to_i
    options[:filter] = "line:#{line_number}"
  elsif File.exist?(arg) && arg.end_with?(".rb")
    # Specific test file
    test_files << arg
  elsif known_targets.include?(arg)
    # Test target (atoms, molecules, unit, etc.)
    target = arg
  elsif !arg.start_with?("-") && target.nil? && !File.exist?(arg)
    # Unrecognized target - will be handled by PatternResolver
    target = arg
  end
end

# Set target and files in options
options[:target] = target if target
options[:files] = test_files unless test_files.empty?

# Handle clean-test-reports command
if target == "clean-test-reports"
  require "ace/test_runner/molecules/report_storage"
  require "fileutils"

  base_dir = options[:report_dir] || "test-reports"

  # Find all report directories
  reports = Dir.glob(File.join(base_dir, "*"))
               .select { |d| File.directory?(d) && !File.symlink?(d) }
               .select { |d| File.basename(d) =~ /^\d{8}-\d{6}$/ }  # Match timestamp format
               .sort
               .reverse  # Most recent first

  if reports.size <= 1
    puts "No old reports to clean up."
  else
    # Keep only the most recent report
    to_delete = reports[1..-1]  # All except the first (most recent)

    puts "Cleaning up test reports (keeping only the latest)..."
    puts "Deleting #{to_delete.size} old reports:"

    to_delete.each do |report_path|
      puts "  - #{File.basename(report_path)}"
      FileUtils.rm_rf(report_path)
    end
  end

  exit 0
end

# Handle Report cleanup commands
if options[:cleanup_reports]
  require "ace/test_runner/molecules/report_storage"

  storage = Ace::TestRunner::Molecules::ReportStorage.new(
    base_dir: options[:report_dir] || "test-reports"
  )

  keep = options[:cleanup_keep] || 10
  age = options[:cleanup_age] || 30

  puts "Cleaning up test reports..."
  puts "  Keeping last #{keep} reports"
  puts "  Deleting reports older than #{age} days"

  deleted = storage.cleanup_old_reports(keep: keep, max_age_days: age)

  if deleted.empty?
    puts "No reports to clean up."
  else
    puts "Deleted #{deleted.size} old reports:"
    deleted.each { |path| puts "  - #{File.basename(path)}" }
  end

  exit 0
end

# Handle Rake integration commands
if options[:set_default_rake] || options[:unset_default_rake] || options[:check_rake_status]
  require "ace/test_runner/molecules/rake_integration"

  integration = Ace::TestRunner::Molecules::RakeIntegration.new

  if options[:set_default_rake]
    result = integration.set_default
    puts result[:message]
    exit(result[:success] ? 0 : 1)
  elsif options[:unset_default_rake]
    result = integration.unset_default
    puts result[:message]
    exit(result[:success] ? 0 : 1)
  elsif options[:check_rake_status]
    status = integration.check_status
    puts "Rake Test Integration Status:"
    puts "  Rakefile exists: #{status[:rakefile_exists]}"
    puts "  ace-test integrated: #{status[:integrated]}"
    puts "  Message: #{status[:message]}"
    puts "  Backup exists: #{status[:backup_exists]}" if status[:backup_exists]
    puts "  Has test task: #{status[:has_test_task]}" if status.key?(:has_test_task)
    exit 0
  end
end

# Handle deprecation fixing mode
if options[:fix_deprecations]
  require "ace/test_runner/molecules/deprecation_fixer"

  puts "Scanning for deprecated test patterns..."

  detector = Ace::TestRunner::Atoms::TestDetector.new
  fixer = Ace::TestRunner::Molecules::DeprecationFixer.new

  test_files = detector.find_test_files
  fixed_count = 0

  test_files.each do |file|
    result = fixer.fix_file(file, dry_run: false)
    if result[:success] && result[:changes] > 0
      puts "  Fixed #{result[:changes]} deprecations in #{file}"
      fixed_count += result[:changes]
    end
  end

  if fixed_count == 0
    puts "No deprecations found to fix."
  else
    puts "Fixed #{fixed_count} deprecations total."
  end

  exit 0
end

# Run tests
begin
  exit_code = Ace::TestRunner.run(options)
  exit exit_code
rescue Ace::TestRunner::Error => e
  puts "Error: #{e.message}"
  exit 1
rescue Interrupt
  puts "\nTest execution interrupted"
  exit 130
rescue => e
  puts "Unexpected error: #{e.message}"
  puts e.backtrace if options[:verbose]
  exit 1
end