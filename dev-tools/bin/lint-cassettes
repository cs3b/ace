#!/usr/bin/env ruby
# frozen_string_literal: true

require 'pathname'
require 'fileutils'

# Lint VCR cassettes for size issues
# Warns about cassettes larger than threshold but never fails
class CassetteLinter
  DEFAULT_THRESHOLD = 50 * 1024 # 50KB in bytes
  CASSETTES_DIR = 'spec/cassettes'

  def initialize(threshold: DEFAULT_THRESHOLD)
    @threshold = threshold
    @cassettes_dir = Pathname.new(CASSETTES_DIR)
  end

  def run
    print_header

    unless cassettes_dir_exists?
      puts "No cassettes directory found at #{@cassettes_dir}"
      puts "This is normal if VCR tests haven't been run yet."
      return
    end

    large_cassettes = find_large_cassettes

    if large_cassettes.empty?
      print_success_message
    else
      print_warnings(large_cassettes)
      print_optimization_tips
    end

    print_summary(large_cassettes)
  end

  private

  def print_header
    puts '🎞️  VCR Cassette Size Linter'
    puts '=' * 50
    puts "Checking for cassettes larger than #{format_size(@threshold)}..."
    puts
  end

  def cassettes_dir_exists?
    @cassettes_dir.exist? && @cassettes_dir.directory?
  end

  def find_large_cassettes
    cassette_files = Dir.glob(@cassettes_dir.join('**', '*.{json,yml}'))

    large_files = []

    cassette_files.each do |file_path|
      file_size = File.size(file_path)

      if file_size > @threshold
        # Ensure we can create a relative path safely
        begin
          relative_path = Pathname.new(file_path).relative_path_from(Pathname.pwd)
          path_display = relative_path.to_s
        rescue ArgumentError
          # Fallback to absolute path if relative path calculation fails
          path_display = file_path
        end

        large_files << {
          path: path_display,
          size: file_size,
          size_formatted: format_size(file_size)
        }
      end
    end

    # Sort by size, largest first
    large_files.sort_by { |file| -file[:size] }
  end

  def print_success_message
    puts '✅ All cassettes are within size limits!'
    puts "   No cassettes exceed #{format_size(@threshold)}"
    puts
  end

  def print_warnings(large_cassettes)
    puts "⚠️  Found #{large_cassettes.length} large cassette(s):"
    puts

    large_cassettes.each_with_index do |cassette, index|
      reduction_percentage = calculate_reduction_percentage(cassette[:size])

      puts "#{index + 1}. #{cassette[:path]}"
      puts "   Size: #{cassette[:size_formatted]} (#{reduction_percentage}% over threshold)"
      puts '   Recommendation: Consider VCR response filtering optimization'
      puts
    end
  end

  def print_optimization_tips
    puts '💡 Optimization Tips:'
    puts
    puts 'Large cassettes often indicate auxiliary data that can be optimized:'
    puts '• Model pricing/metadata responses (common culprit: ~555KB)'
    puts '• Large model lists or configuration data'
    puts '• Verbose API responses with unnecessary fields'
    puts
    puts 'Solution: Add VCR before_record filtering in spec/support/vcr.rb'
    puts 'See: docs/development/guides/testing-with-vcr.md#cassette-size-optimization'
    puts
  end

  def print_summary(large_cassettes)
    total_cassettes = count_total_cassettes
    total_size = calculate_total_size

    puts '📊 Summary:'
    puts "   Total cassettes: #{total_cassettes}"
    puts "   Total size: #{format_size(total_size)}"
    puts "   Large cassettes: #{large_cassettes.length}"

    if large_cassettes.any?
      largest = large_cassettes.first
      puts "   Largest: #{largest[:size_formatted]} (#{File.basename(largest[:path])})"

      potential_savings = large_cassettes.sum { |c| c[:size] - @threshold }
      puts "   Potential savings: #{format_size(potential_savings)} with optimization"
    end

    puts
    puts 'Note: This linter provides warnings only and never fails builds.'
  end

  def count_total_cassettes
    Dir.glob(@cassettes_dir.join('**', '*.{json,yml}')).length
  end

  def calculate_total_size
    Dir.glob(@cassettes_dir.join('**', '*.{json,yml}')).sum { |file| File.size(file) }
  end

  def calculate_reduction_percentage(file_size)
    ((file_size.to_f - @threshold) / @threshold * 100).round(1)
  end

  def format_size(bytes)
    units = ['B', 'KB', 'MB', 'GB']
    size = bytes.to_f
    unit_index = 0

    while size >= 1024 && unit_index < units.length - 1
      size /= 1024.0
      unit_index += 1
    end

    if unit_index == 0
      "#{size.to_i}#{units[unit_index]}"
    else
      "#{size.round(1)}#{units[unit_index]}"
    end
  end
end

# Script execution
if __FILE__ == $0
  # Parse command line arguments
  threshold = nil

  ARGV.each_with_index do |arg, index|
    case arg
    when '--threshold', '-t'
      next_arg = ARGV[index + 1]
      if next_arg && next_arg.match?(/^\d+$/)
        threshold = next_arg.to_i * 1024 # Convert KB to bytes
      else
        puts 'Error: --threshold requires a number (in KB)'
        exit 1
      end
    when '--help', '-h'
      puts 'Usage: bin/lint-cassettes [options]'
      puts
      puts 'Options:'
      puts '  -t, --threshold KB    Size threshold in KB (default: 50)'
      puts '  -h, --help           Show this help message'
      puts
      puts 'Examples:'
      puts '  bin/lint-cassettes              # Use default 50KB threshold'
      puts '  bin/lint-cassettes -t 100       # Use 100KB threshold'
      puts '  bin/lint-cassettes --threshold 25   # Use 25KB threshold'
      puts
      puts 'This tool warns about large VCR cassettes but never fails.'
      puts 'See docs/development/guides/testing-with-vcr.md for optimization tips.'
      exit 0
    end
  end

  linter = CassetteLinter.new(threshold: threshold || CassetteLinter::DEFAULT_THRESHOLD)
  linter.run
end
