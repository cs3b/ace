#!/usr/bin/env ruby
# frozen_string_literal: true

# Ace Review - Automated code review tool
#
# This executable provides code review functionality for the ACE framework.
# It supports preset-based reviews with configurable focus areas using LLM analysis.
#
# Usage: ace-review code [options]
#
# Examples:
#   ace-review code --preset pr
#   ace-review code --preset security --auto-execute
#   ace-review code --list-presets
#
# For more information:
#   ace-review code --help

# Use absolute path resolution to support execution from any directory
lib_path = File.expand_path("../lib", __dir__)
$LOAD_PATH.unshift lib_path unless $LOAD_PATH.include?(lib_path)

require "ace/review"
require "ace/review/cli"
require "dry/cli"

# Execute CLI
Dry::CLI.new(Ace::Review::CLI::Commands).call