#!/usr/bin/env ruby
# frozen_string_literal: true

# Add lib directory to load path
$LOAD_PATH.unshift File.expand_path("../lib", __dir__)

# Load the ace-git-worktree gem
require "ace/git/worktree"
require "dry/cli"

args = ARGV.empty? ? ["--help"] : ARGV

# Start dry-cli with exception-based exit code handling (per ADR-023)
begin
  exit(Ace::Git::Worktree::CLI.start(args))
rescue SystemExit => e
  exit(e.status)
rescue Ace::Core::CLI::Error => e
  warn e.message
  exit(e.exit_code)
end
