#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/ace/taskflow"

# Clear caches before each invocation
Ace::Taskflow::Molecules::TaskLoader.clear_cache!
Ace::Taskflow::Molecules::ReleaseResolver.clear_cache!

# No args → show help
args = ARGV.empty? ? ["--help"] : ARGV

# Start dry-cli with exception-based exit code handling (per ADR-023)
begin
  Ace::Taskflow::TaskCLI.start(args)
rescue Ace::Core::CLI::Error => e
  warn e.message
  exit(e.exit_code)
end
