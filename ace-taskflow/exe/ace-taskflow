#!/usr/bin/env ruby
# frozen_string_literal: true

# Ace Taskflow - Task and release management
#
# This executable provides utility commands for the ACE framework's
# taskflow system including status, health checks, and configuration.

# Use absolute path resolution to support execution from any directory
lib_path = File.expand_path("../lib", __dir__)
$LOAD_PATH.unshift lib_path unless $LOAD_PATH.include?(lib_path)

require "ace/taskflow"
require "dry/cli"

# Clear caches before dispatch (moved from CLI.start override)
Ace::Taskflow::Molecules::TaskLoader.clear_cache!
Ace::Taskflow::Molecules::ReleaseResolver.clear_cache!

# No args → show help
args = ARGV.empty? ? ["--help"] : ARGV

# Start dry-cli with exception-based exit code handling (per ADR-023)
begin
  Dry::CLI.new(Ace::Taskflow::CLI).call(arguments: args)
rescue Ace::Core::CLI::Error => e
  warn e.message
  exit(e.exit_code)
end
