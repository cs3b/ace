# Example environment configuration for coding-agent-tools
# Copy this file to .env and fill in your actual values

# LLM Provider API Keys
# =====================

# Google Gemini API Key
# Get this from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_actual_gemini_api_key_here

# OpenAI API Key
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_actual_openai_api_key_here

# Anthropic Claude API Key
# Get this from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_actual_anthropic_api_key_here

# Mistral AI API Key
# Get this from: https://console.mistral.ai/
MISTRAL_API_KEY=your_actual_mistral_api_key_here

# Together AI API Key
# Get this from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_actual_together_api_key_here

# LM Studio Configuration
# =======================
# LM Studio runs locally and typically doesn't require an API key
# If your setup requires authentication, set this:
# LM_STUDIO_API_KEY=your_lm_studio_api_key_here

# Development Configuration
# =========================

# VCR Configuration
# Set to 'true' when recording new cassettes with real API calls
# VCR_RECORD=false

# Test Environment
# Set to 'test' when running tests
# NODE_ENV=test
