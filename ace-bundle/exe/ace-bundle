#!/usr/bin/env ruby
# frozen_string_literal: true

require "ace/bundle"
require "dry/cli"

# Start dry-cli single-command entrypoint with exception-based exit code handling (per ADR-023)
begin
  args = ARGV.empty? ? ["--help"] : ARGV
  Dry::CLI.new(Ace::Bundle::CLI::Commands::Load).call(arguments: args)
rescue Ace::Core::CLI::Error => e
  warn e.message
  exit(e.exit_code)
end
