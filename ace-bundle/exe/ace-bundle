#!/usr/bin/env ruby
# frozen_string_literal: true

require "ace/bundle"
require "dry/cli"

if ARGV.include?("--list") || ARGV.include?("--list-presets")
  ARGV.delete("--list")
  ARGV.delete("--list-presets")
  ARGV.unshift("list")
end

args = ARGV.empty? ? ["--help"] : ARGV

begin
  Dry::CLI.new(Ace::Bundle::CLI).call(arguments: args)
rescue Ace::Core::CLI::Error => e
  warn e.message
  exit(e.exit_code)
end
