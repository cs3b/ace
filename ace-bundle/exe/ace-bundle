#!/usr/bin/env ruby
# frozen_string_literal: true

require "ace/bundle"

# Handle --list flag (legacy Thor mapping)
if ARGV.include?("--list") || ARGV.include?("--list-presets")
  ARGV.delete("--list")
  ARGV.delete("--list-presets")
  ARGV.unshift("list")
end

# Start dry-cli with exception-based exit code handling (per ADR-023)
begin
  Ace::Bundle::CLI.start(ARGV)
rescue Ace::Core::CLI::Error => e
  warn e.message
  exit(e.exit_code)
end
