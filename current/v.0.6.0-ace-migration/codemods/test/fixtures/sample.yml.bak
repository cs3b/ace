# Test fixture for YAML files
# This file contains various references to dev-* paths that should be updated

project:
  name: Test Project
  directories:
    tools: dev-tools/
    handbook: dev-handbook/
    taskflow: dev-taskflow/
    local: dev-local/

paths:
  - dev-tools/bin
  - dev-handbook/docs
  - dev-taskflow/current
  - dev-local/config

configuration:
  tool_path: "dev-tools/"
  handbook_path: 'dev-handbook/'
  taskflow_path: dev-taskflow/
  local_path: "dev-local/"

scripts:
  build: dev-tools/scripts/build.sh
  test: dev-tools/scripts/test.sh
  docs: dev-handbook/scripts/generate.rb
  deploy: dev-local/scripts/deploy.sh

# Comments with paths
# Located in dev-tools/config
# Documented in dev-handbook/README.md
# Tasks in dev-taskflow/backlog
# Cache in dev-local/tmp

nested:
  deep:
    paths:
      tool: dev-tools/lib/core/tool.rb
      guide: dev-handbook/guides/setup.md
      task: dev-taskflow/done/2024/task.md
      cache: dev-local/cache/data.json

includes:
  - ./dev-tools/config/base.yml
  - ../dev-handbook/config/docs.yml
  - /absolute/path/dev-taskflow/config.yml
  - ~/home/dev-local/settings.yml

environment:
  TOOLS_DIR: ${PWD}/dev-tools/
  HANDBOOK_DIR: "${PWD}/dev-handbook/"
  TASKFLOW_DIR: $PWD/dev-taskflow/
  LOCAL_DIR: "$PWD/dev-local/"

commands:
  - cd dev-tools/ && make build
  - "cd dev-handbook/ && bundle install"
  - 'cd dev-taskflow/ && ls -la'
  - cd dev-local/ && ./setup.sh