module TestModule
  # Constants with path references
  TOOLS_PATH = 'dev-tools/bin'
  HANDBOOK_DIR = "dev-handbook/docs"
  TASKFLOW_ROOT = File.join('dev-taskflow', 'current')
  LOCAL_CONFIG = File.expand_path('dev-local/config')

  class PathProcessor
    def initialize
      @base = 'dev-tools/'
      @handbook = "dev-handbook/"
      @taskflow = 'dev-taskflow/'
      @local = "dev-local/"
    end

    def process
      # Comments should also be updated
      # Load from dev-tools/lib
      # Save to dev-handbook/output
      # Check dev-taskflow/backlog
      # Use dev-local/cache

      paths = [
        'dev-tools/spec',
        'dev-handbook/templates',
        'dev-taskflow/done',
        'dev-local/tmp'
      ]

      paths.map do |path|
        File.join(path, 'data.yml')
      end
    end

    def documentation
      <<~DOC
        This tool uses the following directories:
        - dev-tools/ for executables
        - dev-handbook/ for documentation
        - dev-taskflow/ for task management
        - dev-local/ for local configuration
      DOC
    end
  end
end

